@page "/cargas"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using TankDesigner.Web.Services
@using TankDesigner.Infrastructure.Services
@inject ProyectoState EstadoProyecto
@inject OpcionesFormularioService Opciones
@inject NormativaCargasUiService NormativaUi

<PageTitle>Cargas</PageTitle>

<div class="cargas-page">
    <div class="page-header">
        <h1>Cargas</h1>
        <p>Viento, sismo, sobrecargas y acciones aplicadas al proyecto.</p>
    </div>

    <EditForm Model="EstadoProyecto.Cargas">
        <div class="page-layout">
            <section class="main-column">
                <article class="td-panel">
                    <div class="td-panel__header">
                        <div class="section-kicker">Bloque 01</div>
                        <h2>Contexto normativo</h2>
                        <p>Resumen de la normativa actualmente sincronizada con el proyecto.</p>
                    </div>

                    <div class="summary-list">
                        <div class="summary-row">
                            <span class="summary-row__label">Normativa activa</span>
                            <span class="summary-row__value">@_normativaActiva</span>
                        </div>

                        <div class="summary-row">
                            <span class="summary-row__label">Resumen</span>
                            <span class="summary-row__value">@_resumenNormativa</span>
                        </div>
                    </div>
                </article>

                @if (EsNormativaAwwa())
                {
                    <article class="td-panel">
                        <div class="td-panel__header">
                            <div class="section-kicker">Bloque 02</div>
                            <h2>Cubierta</h2>
                            <p>Definición de variables de cubierta y cargas asociadas para el cálculo estructural.</p>
                        </div>

                        <div class="form-grid">
                            <div class="field">
                                <label>Tipo de techo</label>
                                <InputSelect class="td-input td-select"
                                             @bind-Value="EstadoProyecto.Cargas.RoofType"
                                             @bind-Value:after="OnRoofTypeChanged">
                                    @foreach (var item in _roofTypes)
                                    {
                                        <option value="@item">@item</option>
                                    }
                                </InputSelect>
                                <small>Si el techo es None, todas las cargas de cubierta se guardan a 0.</small>
                            </div>

                            <div class="field">
                                <label>Ángulo superior</label>
                                <InputSelect class="td-input td-select"
                                             @bind-Value="EstadoProyecto.Cargas.AnguloSuperior"
                                             @bind-Value:after="OnAnguloSuperiorChanged"
                                             disabled="@EsTechoNoneSeleccionado()">
                                    <option value="">Seleccione...</option>
                                    @foreach (var item in _angulosSuperiores)
                                    {
                                        <option value="@item">@item</option>
                                    }
                                </InputSelect>
                                <small>Opciones reales cargadas desde ListaPosiblesRigidizadoresSuperiores.json.</small>
                            </div>

                            <div class="field">
                                <label>Carga muerta de cubierta</label>
                                <InputNumber class="td-input"
                                             @bind-Value="EstadoProyecto.Cargas.RoofDeadLoad"
                                             @bind-Value:after="AplicarReglasTecho"
                                             disabled="@EsTechoNoneSeleccionado()" />
                                <small>Carga permanente correspondiente al sistema de cubierta.</small>
                            </div>

                            <div class="field">
                                <label>Carga de nieve</label>
                                <InputNumber class="td-input"
                                             @bind-Value="EstadoProyecto.Cargas.RoofSnowLoad"
                                             @bind-Value:after="AplicarReglasTecho"
                                             disabled="@EsTechoNoneSeleccionado()" />
                                <small>Acción de nieve considerada sobre la cubierta.</small>
                            </div>

                            <div class="field">
                                <label>Sobrecarga de uso</label>
                                <InputNumber class="td-input"
                                             @bind-Value="EstadoProyecto.Cargas.RoofLiveLoad"
                                             @bind-Value:after="AplicarReglasTecho"
                                             disabled="@EsTechoNoneSeleccionado()" />
                                <small>Sobrecarga por mantenimiento, uso o acceso.</small>
                            </div>

                            <div class="field">
                                <label>Centroide de cubierta</label>
                                <InputNumber class="td-input"
                                             @bind-Value="EstadoProyecto.Cargas.RoofCentroid"
                                             @bind-Value:after="AplicarReglasTecho"
                                             disabled="@EsTechoNoneSeleccionado()" />
                                <small>Posición del centroide empleada en cálculos derivados.</small>
                            </div>

                            <div class="field field--full">
                                <label>Área proyectada de cubierta</label>
                                <InputNumber class="td-input"
                                             @bind-Value="EstadoProyecto.Cargas.RoofProjectedArea"
                                             @bind-Value:after="AplicarReglasTecho"
                                             disabled="@EsTechoNoneSeleccionado()" />
                                <small>Área proyectada utilizada en comprobaciones estructurales.</small>
                            </div>
                        </div>
                    </article>

                    <article class="td-panel">
                        <div class="td-panel__header">
                            <div class="section-kicker">Bloque 03</div>
                            <h2>Viento y sismo</h2>
                            <p>Parámetros normativos para acciones horizontales y comprobaciones sísmicas.</p>
                        </div>

                        <div class="form-grid">
                            <div class="field">
                                <label>Velocidad del viento</label>
                                <InputNumber class="td-input" @bind-Value="EstadoProyecto.Cargas.VelocidadViento" />
                                <small>Velocidad básica de viento aplicada al modelo.</small>
                            </div>

                            <div class="field">
                                <label>Clase de exposición</label>
                                <InputSelect class="td-input td-select" @bind-Value="EstadoProyecto.Cargas.ClaseExposicion">
                                    @foreach (var item in _clasesExposicion)
                                    {
                                        <option value="@item">@item</option>
                                    }
                                </InputSelect>
                                <small>Clasificación de exposición frente a la acción del viento.</small>
                            </div>

                            <div class="field">
                                <label>Ss</label>
                                <InputNumber class="td-input" @bind-Value="EstadoProyecto.Cargas.Ss" />
                                <small>Parámetro sísmico de corto periodo.</small>
                            </div>

                            <div class="field">
                                <label>S1</label>
                                <InputNumber class="td-input" @bind-Value="EstadoProyecto.Cargas.S1" />
                                <small>Parámetro sísmico para periodo de 1 segundo.</small>
                            </div>

                            <div class="field">
                                <label>TL</label>
                                <InputNumber class="td-input" @bind-Value="EstadoProyecto.Cargas.TL" />
                                <small>Periodo largo de transición.</small>
                            </div>

                            <div class="field">
                                <label>Site Class</label>
                                <InputSelect class="td-input td-select" @bind-Value="EstadoProyecto.Cargas.SiteClass">
                                    @foreach (var item in _siteClasses)
                                    {
                                        <option value="@item">@item</option>
                                    }
                                </InputSelect>
                                <small>Clasificación del terreno o emplazamiento.</small>
                            </div>

                            <div class="field field--full">
                                <label>Seismic Use Group</label>
                                <InputSelect class="td-input td-select" @bind-Value="EstadoProyecto.Cargas.SeismicUseGroup">
                                    @foreach (var item in _seismicUseGroups)
                                    {
                                        <option value="@item">@item</option>
                                    }
                                </InputSelect>
                                <small>Grupo de uso sísmico aplicado en la evaluación estructural.</small>
                            </div>
                        </div>
                    </article>
                }
                else
                {
                    <article class="td-panel">
                        <div class="td-panel__header">
                            <div class="section-kicker">Bloque 02</div>
                            <h2>Normativa provisional</h2>
                            <p>Para ISO y EC se mantienen valores y observaciones provisionales alineados con la lógica existente.</p>
                        </div>

                        <div class="summary-list">
                            <div class="summary-row">
                                <span class="summary-row__label">Normativa</span>
                                <span class="summary-row__value">@_normativaActiva</span>
                            </div>
                            <div class="summary-row">
                                <span class="summary-row__label">Observaciones</span>
                                <span class="summary-row__value">@TextoSeguro(EstadoProyecto.Cargas.Observaciones)</span>
                            </div>
                        </div>
                    </article>
                }
            </section>

            <aside class="side-column">
                <article class="td-panel td-panel--compact td-panel--sticky">
                    <div class="td-panel__header">
                        <div class="section-kicker">Resumen vivo</div>
                        <h2>Resumen de cargas</h2>
                        <p>Vista rápida de los parámetros principales actualmente definidos.</p>
                    </div>

                    <div class="summary-list">
                        <div class="summary-row">
                            <span class="summary-row__label">Normativa</span>
                            <span class="summary-row__value">@TextoSeguro(EstadoProyecto.Cargas.NormativaAplicada)</span>
                        </div>
                        <div class="summary-row">
                            <span class="summary-row__label">Velocidad viento</span>
                            <span class="summary-row__value">@ValorNumero(EstadoProyecto.Cargas.VelocidadViento)</span>
                        </div>
                        <div class="summary-row">
                            <span class="summary-row__label">Carga de nieve</span>
                            <span class="summary-row__value">@ValorNumero(ObtenerCargaNieveVisible())</span>
                        </div>
                        <div class="summary-row">
                            <span class="summary-row__label">Tipo de techo</span>
                            <span class="summary-row__value">@TextoSeguro(EstadoProyecto.Cargas.RoofType)</span>
                        </div>
                        <div class="summary-row">
                            <span class="summary-row__label">Ángulo superior</span>
                            <span class="summary-row__value">@TextoSeguro(EstadoProyecto.Cargas.AnguloSuperior)</span>
                        </div>
                        <div class="summary-row">
                            <span class="summary-row__label">Exposición</span>
                            <span class="summary-row__value">@TextoSeguro(EstadoProyecto.Cargas.ClaseExposicion)</span>
                        </div>
                        <div class="summary-row">
                            <span class="summary-row__label">Site Class</span>
                            <span class="summary-row__value">@TextoSeguro(EstadoProyecto.Cargas.SiteClass)</span>
                        </div>
                        <div class="summary-row">
                            <span class="summary-row__label">Seismic Use Group</span>
                            <span class="summary-row__value">@TextoSeguro(EstadoProyecto.Cargas.SeismicUseGroup)</span>
                        </div>
                    </div>
                </article>
            </aside>
        </div>
    </EditForm>
</div>

@code {
    private string _normativaActiva = "AWWA";
    private string _resumenNormativa = string.Empty;
    private List<string> _angulosSuperiores = new();
    private List<string> _roofTypes = new();
    private List<string> _clasesExposicion = new();
    private List<string> _siteClasses = new();
    private List<string> _seismicUseGroups = new();

    protected override void OnInitialized()
    {
        _roofTypes = Opciones.ObtenerRoofTypes();
        _clasesExposicion = Opciones.ObtenerClasesExposicion();
        _siteClasses = Opciones.ObtenerSiteClasses();
        _seismicUseGroups = Opciones.ObtenerSeismicUseGroups();

        CargarAngulosSuperiores();
        SincronizarNormativa();
    }

    protected override void OnParametersSet()
    {
        SincronizarNormativa();
    }

    private void CargarAngulosSuperiores()
    {
        _angulosSuperiores = Opciones.ObtenerAngulosSuperiores(EstadoProyecto.Proyecto.Fabricante);

        if (_angulosSuperiores.Count == 0)
            _angulosSuperiores.Add("0");
    }

    private void SincronizarNormativa()
    {
        _normativaActiva = NormativaUi.NormalizarNormativa(EstadoProyecto.Proyecto.Normativa);
        EstadoProyecto.Cargas.NormativaAplicada = _normativaActiva;

        if (EstadoProyecto.Tanque.DensidadLiquido > 0)
            EstadoProyecto.Cargas.DensidadLiquido = EstadoProyecto.Tanque.DensidadLiquido;

        if (string.IsNullOrWhiteSpace(EstadoProyecto.Cargas.RoofType)
            && !string.IsNullOrWhiteSpace(EstadoProyecto.Instalacion.TipoTecho)
            && !EstadoProyecto.Instalacion.TipoTecho.Equals("Sin techo", StringComparison.OrdinalIgnoreCase))
        {
            EstadoProyecto.Cargas.RoofType = EstadoProyecto.Instalacion.TipoTecho;
        }

        if (string.IsNullOrWhiteSpace(EstadoProyecto.Cargas.RoofType))
            EstadoProyecto.Cargas.RoofType = "None";

        if (string.IsNullOrWhiteSpace(EstadoProyecto.Cargas.ClaseExposicion) && _clasesExposicion.Any())
            EstadoProyecto.Cargas.ClaseExposicion = _clasesExposicion.First();

        if (string.IsNullOrWhiteSpace(EstadoProyecto.Cargas.SiteClass) && _siteClasses.Any())
            EstadoProyecto.Cargas.SiteClass = _siteClasses.First();

        if (string.IsNullOrWhiteSpace(EstadoProyecto.Cargas.SeismicUseGroup) && _seismicUseGroups.Any())
            EstadoProyecto.Cargas.SeismicUseGroup = _seismicUseGroups.First();

        CargarAngulosSuperiores();

        if (!EsTechoNoneSeleccionado())
        {
            if (string.IsNullOrWhiteSpace(EstadoProyecto.Cargas.AnguloSuperior) || !_angulosSuperiores.Contains(EstadoProyecto.Cargas.AnguloSuperior))
                EstadoProyecto.Cargas.AnguloSuperior = _angulosSuperiores.First();

            EstadoProyecto.Cargas.RoofAngle = EstadoProyecto.Cargas.AnguloSuperior;
        }

        AplicarReglasTecho();
        _resumenNormativa = NormativaUi.ConstruirResumenVisual(_normativaActiva);
    }

    private void OnRoofTypeChanged()
    {
        CargarAngulosSuperiores();

        if (EsTechoNoneSeleccionado())
        {
            AplicarReglasTecho();
            return;
        }

        if (string.IsNullOrWhiteSpace(EstadoProyecto.Cargas.AnguloSuperior) || !_angulosSuperiores.Contains(EstadoProyecto.Cargas.AnguloSuperior))
            EstadoProyecto.Cargas.AnguloSuperior = _angulosSuperiores.First();

        EstadoProyecto.Cargas.RoofAngle = EstadoProyecto.Cargas.AnguloSuperior;

        AplicarReglasTecho();
    }

    private void OnAnguloSuperiorChanged()
    {
        if (EsTechoNoneSeleccionado())
        {
            EstadoProyecto.Cargas.AnguloSuperior = string.Empty;
            EstadoProyecto.Cargas.RoofAngle = "0";
            return;
        }

        if (string.IsNullOrWhiteSpace(EstadoProyecto.Cargas.AnguloSuperior) || !_angulosSuperiores.Contains(EstadoProyecto.Cargas.AnguloSuperior))
            EstadoProyecto.Cargas.AnguloSuperior = _angulosSuperiores.FirstOrDefault() ?? "0";

        EstadoProyecto.Cargas.RoofAngle = EstadoProyecto.Cargas.AnguloSuperior;
    }

    private void AplicarReglasTecho()
    {
        if (EsTechoNoneSeleccionado())
        {
            EstadoProyecto.Cargas.RoofDeadLoad = 0;
            EstadoProyecto.Cargas.RoofSnowLoad = 0;
            EstadoProyecto.Cargas.RoofLiveLoad = 0;
            EstadoProyecto.Cargas.RoofCentroid = 0;
            EstadoProyecto.Cargas.RoofProjectedArea = 0;
            EstadoProyecto.Cargas.RoofAngle = "0";
            EstadoProyecto.Cargas.AnguloSuperior = string.Empty;
        }
        else
        {
            if (string.IsNullOrWhiteSpace(EstadoProyecto.Cargas.AnguloSuperior))
                EstadoProyecto.Cargas.AnguloSuperior = "0";

            EstadoProyecto.Cargas.RoofAngle = EstadoProyecto.Cargas.AnguloSuperior;
        }

        StateHasChanged();
    }

    private bool EsNormativaAwwa()
    {
        return string.Equals(_normativaActiva, "AWWA", StringComparison.OrdinalIgnoreCase)
               || string.Equals(_normativaActiva, "AWWA D103-19", StringComparison.OrdinalIgnoreCase);
    }

    private bool EsTechoNoneSeleccionado()
    {
        return string.IsNullOrWhiteSpace(EstadoProyecto.Cargas.RoofType)
               || EstadoProyecto.Cargas.RoofType.Equals("None", StringComparison.OrdinalIgnoreCase)
               || EstadoProyecto.Cargas.RoofType.Equals("Sin techo", StringComparison.OrdinalIgnoreCase);
    }

    private double ObtenerCargaNieveVisible()
    {
        return EstadoProyecto.Cargas.RoofSnowLoad > 0
            ? EstadoProyecto.Cargas.RoofSnowLoad
            : EstadoProyecto.Cargas.SnowLoad;
    }

    private string TextoSeguro(string? texto)
    {
        return string.IsNullOrWhiteSpace(texto) ? "—" : texto.Trim();
    }

    private string ValorNumero(double valor)
    {
        return valor > 0 ? valor.ToString("0.###") : "—";
    }
}