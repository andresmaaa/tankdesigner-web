@page "/admin/usuarios"
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using TankDesigner.Web.Data
@using TankDesigner.Web.Services
@attribute [Authorize(Roles = RolesAplicacion.SuperAdmin)]

@inject AdminService AdminService
@inject InvitacionesService InvitacionesService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject UserManager<ApplicationUser> UserManager

<PageTitle>Administración - Usuarios</PageTitle>

<div class="informes-page">
    <div class="page-header">
        <h1>Administración de usuarios</h1>
        <p>Gestiona los permisos de acceso de la plataforma.</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(_mensaje))
    {
        <div class="alert-box">
            <div class="alert-box__title">Gestión de usuarios</div>
            <div>@_mensaje</div>
        </div>
    }

    <article class="td-panel" style="margin-bottom:24px;">
        <div class="td-panel__header">
            <div>
                <div class="section-kicker">Invitaciones</div>
                <h2>Invitar a administrador o superadmin</h2>
                <p>Genera un enlace profesional para que el usuario active su permiso al registrarse o iniciar sesión.</p>
            </div>
        </div>

        <EditForm Model="_nuevaInvitacion" OnValidSubmit="CrearInvitacion">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="summary-list">
                <div class="summary-row" style="align-items:end; gap:18px; flex-wrap:wrap;">
                    <div style="min-width:280px; flex:1;">
                        <div class="summary-row__label">Correo electrónico</div>
                        <InputText class="td-input" @bind-Value="_nuevaInvitacion.Email" />
                    </div>

                    <div style="min-width:220px;">
                        <div class="summary-row__label">Rol a asignar</div>
                        <InputSelect class="td-input" @bind-Value="_nuevaInvitacion.RolAsignado">
                            <option value="Admin">Admin</option>
                            <option value="SuperAdmin">SuperAdmin</option>
                        </InputSelect>
                    </div>

                    <div>
                        <button type="submit" class="action-btn action-btn--primary" disabled="@_procesandoInvitacion">
                            @(_procesandoInvitacion ? "Generando..." : "Generar invitación")
                        </button>
                    </div>
                </div>
            </div>
        </EditForm>

        @if (!string.IsNullOrWhiteSpace(_ultimoEnlaceGenerado))
        {
            <div class="summary-list" style="margin-top:18px;">
                <div class="summary-row" style="display:block;">
                    <div class="summary-row__label">Enlace generado</div>
                    <div class="summary-row__value" style="word-break:break-all;">@_ultimoEnlaceGenerado</div>
                </div>
            </div>
        }

        @if (_invitacionesPendientes.Count > 0)
        {
            <div class="summary-list" style="margin-top:18px;">
                @foreach (var invitacion in _invitacionesPendientes)
                {
                    <div class="summary-row" style="align-items:center; gap:18px; flex-wrap:wrap;">
                        <div style="min-width:240px;">
                            <div class="summary-row__label">Correo</div>
                            <div class="summary-row__value">@invitacion.Email</div>
                        </div>

                        <div style="min-width:140px;">
                            <div class="summary-row__label">Rol</div>
                            <div class="summary-row__value">@invitacion.RolAsignado</div>
                        </div>

                        <div style="min-width:180px;">
                            <div class="summary-row__label">Expira</div>
                            <div class="summary-row__value">@invitacion.FechaExpiracion.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                        </div>

                        <div style="flex:1; min-width:260px;">
                            <div class="summary-row__label">Enlace</div>
                            <div class="summary-row__value" style="word-break:break-all;">@ConstruirEnlaceInvitacion(invitacion.Token)</div>
                        </div>
                    </div>
                }
            </div>
        }
    </article>

    <article class="td-panel">
        <div class="td-panel__header">
            <div>
                <div class="section-kicker">Panel de administración</div>
                <h2>Usuarios registrados</h2>
                <p>Solo el SuperAdmin puede asignar o retirar permisos de administrador.</p>
            </div>
        </div>

        @if (_usuarios.Count == 0)
        {
            <p>No hay usuarios registrados.</p>
        }
        else
        {
            <div class="summary-list">
                @foreach (var usuario in _usuarios)
                {
                    <div class="summary-row" style="align-items:center; gap:18px; flex-wrap:wrap;">
                        <div style="min-width:260px;">
                            <div class="summary-row__label">Correo</div>
                            <div class="summary-row__value">@usuario.Email</div>
                        </div>

                        <div style="min-width:160px;">
                            <div class="summary-row__label">Nombre</div>
                            <div class="summary-row__value">
                                @(string.IsNullOrWhiteSpace(usuario.NombreCompleto) ? "—" : usuario.NombreCompleto)
                            </div>
                        </div>

                        <div style="min-width:180px;">
                            <div class="summary-row__label">Rol actual</div>
                            <div class="summary-row__value">
                                @if (usuario.EsSuperAdmin)
                                {
                                    <span>SuperAdmin</span>
                                }
                                else if (usuario.EsAdmin)
                                {
                                    <span>Admin</span>
                                }
                                else
                                {
                                    <span>Usuario</span>
                                }
                            </div>
                        </div>

                        <div style="display:flex; gap:10px; flex-wrap:wrap;">
                            @if (usuario.EsSuperAdmin)
                            {
                                <button type="button" class="action-btn action-btn--gray" disabled>
                                    SuperAdmin protegido
                                </button>
                            }
                            else if (!usuario.EsAdmin)
                            {
                                <button type="button" class="action-btn action-btn--primary" @onclick="() => HacerAdmin(usuario.Id)">
                                    Hacer admin
                                </button>
                            }
                            else
                            {
                                <button type="button" class="action-btn action-btn--gray" @onclick="() => QuitarAdmin(usuario.Id)">
                                    Quitar admin
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </article>
</div>

@code {
    private List<UsuarioAdminDto> _usuarios = new();
    private List<InvitacionUsuarioDto> _invitacionesPendientes = new();
    private string _mensaje = string.Empty;
    private string _ultimoEnlaceGenerado = string.Empty;
    private ClaimsPrincipal? _usuarioActual;
    private bool _procesandoInvitacion;

    private CrearInvitacionModel _nuevaInvitacion = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _usuarioActual = authState.User;

        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        _usuarios = await AdminService.ObtenerUsuariosAsync();
        _invitacionesPendientes = await InvitacionesService.ObtenerInvitacionesPendientesAsync();
    }

    private async Task CrearInvitacion()
    {
        if (_usuarioActual is null || _procesandoInvitacion)
            return;

        _procesandoInvitacion = true;
        _mensaje = string.Empty;
        _ultimoEnlaceGenerado = string.Empty;

        try
        {
            var usuario = await UserManager.GetUserAsync(_usuarioActual);
            var resultado = await InvitacionesService.CrearInvitacionAsync(
                _nuevaInvitacion.Email,
                _nuevaInvitacion.RolAsignado,
                usuario?.Id);

            _mensaje = resultado.Mensaje;

            if (resultado.Ok && resultado.Invitacion is not null)
            {
                _ultimoEnlaceGenerado = ConstruirEnlaceInvitacion(resultado.Invitacion.Token);
                _nuevaInvitacion = new CrearInvitacionModel();
            }

            await CargarDatos();
        }
        finally
        {
            _procesandoInvitacion = false;
        }
    }

    private async Task HacerAdmin(string userId)
    {
        if (_usuarioActual is null)
            return;

        var ok = await AdminService.HacerAdminAsync(userId, _usuarioActual);

        _mensaje = ok
            ? "Usuario actualizado a administrador."
            : "No tienes permisos para realizar esta acción o el usuario está protegido.";

        await CargarDatos();
    }

    private async Task QuitarAdmin(string userId)
    {
        if (_usuarioActual is null)
            return;

        var ok = await AdminService.QuitarAdminAsync(userId, _usuarioActual);

        _mensaje = ok
            ? "Rol de administrador eliminado correctamente."
            : "No tienes permisos para realizar esta acción o el usuario está protegido.";

        await CargarDatos();
    }

    private string ConstruirEnlaceInvitacion(string token)
    {
        return NavigationManager.ToAbsoluteUri($"/invitacion/{token}").ToString();
    }

    private sealed class CrearInvitacionModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "El correo es obligatorio.")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Introduce un correo válido.")]
        public string Email { get; set; } = string.Empty;

        public string RolAsignado { get; set; } = RolesAplicacion.SuperAdmin;
    }
}
