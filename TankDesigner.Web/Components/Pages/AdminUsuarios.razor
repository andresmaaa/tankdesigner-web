@page "/admin/usuarios"
@attribute [Authorize(Roles = "Admin,SuperAdmin")]
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop
@using TankDesigner.Web.Data
@using TankDesigner.Web.Services
@attribute [Authorize(Roles = RolesAplicacion.SuperAdmin)]

@inject AdminService AdminService
@inject InvitacionesService InvitacionesService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageTitle>Administración - Usuarios</PageTitle>

<div class="informes-page">
    <div class="page-header">
        <h1>Administración de usuarios</h1>
        <p>Gestiona permisos, invitaciones y accesos de la plataforma.</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(_mensaje))
    {
        <div class="alert-box">
            <div class="alert-box__title">Gestión de usuarios</div>
            <div>@_mensaje</div>
        </div>
    }

    <article class="td-panel" style="margin-bottom:18px;">
        <div class="td-panel__header">
            <div>
                <div class="section-kicker">Invitaciones</div>
                <h2>Crear invitación</h2>
                <p>
                    Genera un enlace único. Cuando el usuario acceda con ese enlace y
                    se registre o inicie sesión con ese mismo correo, se le aplicará el rol indicado.
                </p>
            </div>
        </div>

        <div class="summary-list">
            <div class="summary-row" style="align-items:end; gap:16px; flex-wrap:wrap;">
                <div style="min-width:280px;">
                    <div class="summary-row__label">Correo electrónico</div>
                    <input class="td-input" @bind="_emailInvitacion" />
                </div>

                <div style="min-width:180px;">
                    <div class="summary-row__label">Rol a asignar</div>
                    <select class="td-input" @bind="_rolInvitacion">
                        <option value="@RolesAplicacion.Admin">Admin</option>
                        <option value="@RolesAplicacion.SuperAdmin">SuperAdmin</option>
                    </select>
                </div>

                <div>
                    <button type="button" class="action-btn action-btn--primary" @onclick="CrearInvitacion">
                        Generar enlace
                    </button>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(_enlaceInvitacion))
            {
                <div class="summary-row" style="margin-top:14px; flex-direction:column; align-items:flex-start; gap:10px;">
                    <div class="summary-row__label">Enlace generado</div>

                    <div style="display:flex; gap:10px; flex-wrap:wrap; width:100%;">
                        <input class="td-input" style="min-width:420px; flex:1;" readonly value="@_enlaceInvitacion" />

                        <button type="button" class="action-btn action-btn--gray" @onclick="CopiarEnlace">
                            Copiar enlace
                        </button>
                    </div>

                    <div class="summary-row__value">
                        El usuario debe abrir este enlace y acceder con el correo invitado.
                    </div>
                </div>
            }
        </div>
    </article>

    <article class="td-panel">
        <div class="td-panel__header">
            <div>
                <div class="section-kicker">Panel de administración</div>
                <h2>Usuarios registrados</h2>
                <p>Solo el SuperAdmin puede asignar o retirar permisos de administrador.</p>
            </div>
        </div>

        @if (_usuarios.Count == 0)
        {
            <p>No hay usuarios registrados.</p>
        }
        else
        {
            <div class="summary-list">
                @foreach (var usuario in _usuarios)
                {
                    <div class="summary-row" style="align-items:center; gap:18px; flex-wrap:wrap;">
                        <div style="min-width:260px;">
                            <div class="summary-row__label">Correo</div>
                            <div class="summary-row__value">@usuario.Email</div>
                        </div>

                        <div style="min-width:160px;">
                            <div class="summary-row__label">Nombre</div>
                            <div class="summary-row__value">
                                @(string.IsNullOrWhiteSpace(usuario.NombreCompleto) ? "—" : usuario.NombreCompleto)
                            </div>
                        </div>

                        <div style="min-width:180px;">
                            <div class="summary-row__label">Rol actual</div>
                            <div class="summary-row__value">
                                <span class="@ObtenerClaseRol(usuario)">
                                    @ObtenerTextoRol(usuario)
                                </span>
                            </div>
                        </div>

                        <div style="display:flex; gap:10px; flex-wrap:wrap;">
                            @if (usuario.EsSuperAdmin)
                            {
                                <button type="button" class="action-btn action-btn--gray" disabled>
                                    SuperAdmin protegido
                                </button>
                            }
                            else if (!usuario.EsAdmin)
                            {
                                <button type="button" class="action-btn action-btn--primary" @onclick="() => HacerAdmin(usuario.Id)">
                                    Hacer admin
                                </button>
                            }
                            else
                            {
                                <button type="button" class="action-btn action-btn--gray" @onclick="() => QuitarAdmin(usuario.Id)">
                                    Quitar admin
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </article>
</div>

@code {
    private List<UsuarioAdminDto> _usuarios = new();
    private string _mensaje = string.Empty;
    private ClaimsPrincipal? _usuarioActual;

    private string _emailInvitacion = string.Empty;
    private string _rolInvitacion = RolesAplicacion.Admin;
    private string _enlaceInvitacion = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _usuarioActual = authState.User;

        await CargarUsuarios();
    }

    private async Task CargarUsuarios()
    {
        _usuarios = await AdminService.ObtenerUsuariosAsync();
    }

    private async Task HacerAdmin(string userId)
    {
        if (_usuarioActual is null)
            return;

        var ok = await AdminService.HacerAdminAsync(userId, _usuarioActual);

        _mensaje = ok
            ? "Usuario actualizado a administrador."
            : "No tienes permisos para realizar esta acción o el usuario está protegido.";

        await CargarUsuarios();
    }

    private async Task QuitarAdmin(string userId)
    {
        if (_usuarioActual is null)
            return;

        var ok = await AdminService.QuitarAdminAsync(userId, _usuarioActual);

        _mensaje = ok
            ? "Rol de administrador eliminado correctamente."
            : "No tienes permisos para realizar esta acción o el usuario está protegido.";

        await CargarUsuarios();
    }

    private async Task CrearInvitacion()
    {
        if (_usuarioActual is null)
            return;

        var userId = _usuarioActual.FindFirstValue(ClaimTypes.NameIdentifier);

        if (string.IsNullOrWhiteSpace(_emailInvitacion))
        {
            _mensaje = "Debes indicar un correo electrónico.";
            return;
        }

        var resultado = await InvitacionesService.CrearInvitacionAsync(
            _emailInvitacion,
            _rolInvitacion,
            userId);

        if (!resultado.Ok || string.IsNullOrWhiteSpace(resultado.Token))
        {
            _mensaje = resultado.Mensaje;
            return;
        }

        _enlaceInvitacion = $"{NavigationManager.BaseUri}invitacion/{resultado.Token}";
        _mensaje = $"Invitación creada correctamente para {_emailInvitacion}.";
    }

    private async Task CopiarEnlace()
    {
        if (string.IsNullOrWhiteSpace(_enlaceInvitacion))
            return;

        await JS.InvokeVoidAsync("navigator.clipboard.writeText", _enlaceInvitacion);
        _mensaje = "Enlace copiado al portapapeles.";
    }

    private static string ObtenerTextoRol(UsuarioAdminDto usuario)
    {
        if (usuario.EsSuperAdmin)
            return "SuperAdmin";

        if (usuario.EsAdmin)
            return "Admin";

        return "Usuario";
    }

    private static string ObtenerClaseRol(UsuarioAdminDto usuario)
    {
        if (usuario.EsSuperAdmin)
            return "role-badge role-badge--superadmin";

        if (usuario.EsAdmin)
            return "role-badge role-badge--admin";

        return "role-badge role-badge--usuario";
    }
}