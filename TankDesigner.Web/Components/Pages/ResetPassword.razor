@page "/auth/reset-password"

@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Components
@using TankDesigner.Web.Data

@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Nav

<h3>Nueva contraseña</h3>

<input @bind="Password" placeholder="Nueva contraseña" type="password" />

<button @onclick="Reset">Cambiar contraseña</button>

@if (!string.IsNullOrWhiteSpace(Mensaje))
{
    <p>@Mensaje</p>
}

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "email")]
    public string? Email { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    private string Password { get; set; } = "";
    private string? Mensaje;

    private async Task Reset()
    {
        if (string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Token))
        {
            Mensaje = "El enlace de recuperación no es válido.";
            return;
        }

        var user = await UserManager.FindByEmailAsync(Email);

        if (user == null)
        {
            Mensaje = "El enlace de recuperación no es válido.";
            return;
        }

        var result = await UserManager.ResetPasswordAsync(user, Token, Password);

        if (result.Succeeded)
        {
            Nav.NavigateTo("/login?passwordReset=1", forceLoad: true);
            return;
        }

        Mensaje = string.Join(" ", result.Errors.Select(e => e.Description));
    }
}