@page "/reset-password"

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using System.ComponentModel.DataAnnotations
@using System.Text
@using TankDesigner.Web.Data

@attribute [AllowAnonymous]

@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager NavigationManager

<PageTitle>Nueva contraseña</PageTitle>

<div class="auth-page">
    <div class="auth-card auth-card--recovery">
        <div class="auth-card__header">
            <div class="auth-kicker">Acceso seguro</div>
            <h1>Nueva contraseña</h1>
            <p>Introduce una nueva contraseña para recuperar el acceso a tu cuenta.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(Mensaje))
        {
            <div class="auth-alert auth-alert--error">@Mensaje</div>
        }

        <EditForm Model="_model" OnValidSubmit="CambiarPasswordAsync">
            <DataAnnotationsValidator />

            <div class="auth-form">
                <div class="auth-field">
                    <label>Nueva contraseña</label>
                    <InputText class="auth-input"
                               type="password"
                               @bind-Value="_model.Password"
                               placeholder="Nueva contraseña"
                               autocomplete="new-password" />
                    <ValidationMessage For="@(() => _model.Password)" />
                </div>

                <div class="auth-field">
                    <label>Confirmar contraseña</label>
                    <InputText class="auth-input"
                               type="password"
                               @bind-Value="_model.ConfirmPassword"
                               placeholder="Repite la contraseña"
                               autocomplete="new-password" />
                    <ValidationMessage For="@(() => _model.ConfirmPassword)" />
                </div>

                <button type="submit" class="auth-btn auth-btn--primary" disabled="@_procesando">
                    @(_procesando ? "Cambiando contraseña..." : "Cambiar contraseña")
                </button>
            </div>
        </EditForm>

        <div class="auth-footer auth-footer--center">
            <a href="/login">Volver al inicio de sesión</a>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "email")]
    public string? Email { get; set; }

    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    private readonly ResetPasswordModel _model = new();
    private bool _procesando;
    private string? Mensaje;

    private async Task CambiarPasswordAsync()
    {
        _procesando = true;
        Mensaje = null;

        try
        {
            if (string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Token))
            {
                Mensaje = "El enlace de recuperación no es válido.";
                return;
            }

            var usuario = await UserManager.FindByEmailAsync(Email.Trim().ToLowerInvariant());

            if (usuario is null)
            {
                Mensaje = "El enlace de recuperación no es válido.";
                return;
            }

            var tokenDecodificado = Encoding.UTF8.GetString(WebEncoders.Base64UrlDecode(Token));

            var resultado = await UserManager.ResetPasswordAsync(usuario, tokenDecodificado, _model.Password);

            if (resultado.Succeeded)
            {
                NavigationManager.NavigateTo("/login?passwordReset=1", forceLoad: true);
                return;
            }

            Mensaje = string.Join(" ", resultado.Errors.Select(e => e.Description));
        }
        catch
        {
            Mensaje = "No se ha podido cambiar la contraseña. Solicita un nuevo enlace.";
        }
        finally
        {
            _procesando = false;
        }
    }

    private class ResetPasswordModel
    {
        [Required(ErrorMessage = "Introduce una nueva contraseña.")]
        [MinLength(8, ErrorMessage = "La contraseña debe tener al menos 8 caracteres.")]
        public string Password { get; set; } = "";

        [Required(ErrorMessage = "Confirma la contraseña.")]
        [Compare(nameof(Password), ErrorMessage = "Las contraseñas no coinciden.")]
        public string ConfirmPassword { get; set; } = "";
    }
}