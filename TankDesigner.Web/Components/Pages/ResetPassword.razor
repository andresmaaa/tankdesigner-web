@page "/reset-password"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Antiforgery
@using Microsoft.AspNetCore.Http

@attribute [AllowAnonymous]

@inject NavigationManager NavigationManager
@inject IAntiforgery Antiforgery
@inject IHttpContextAccessor HttpContextAccessor

<PageTitle>Nueva contraseña</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-card__header">
            <h1>Nueva contraseña</h1>
            <p>Introduce una contraseña segura para recuperar el acceso a tu cuenta.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(ObtenerError()))
        {
            <div class="auth-alert auth-alert--error">@ObtenerError()</div>
        }

        @if (DatosInvalidos())
        {
            <div class="auth-alert auth-alert--error">
                El enlace de recuperación no es válido o está incompleto. Solicita uno nuevo.
            </div>

            <div class="auth-footer">
                <a href="/forgot-password">Solicitar nuevo enlace</a>
            </div>
        }
        else
        {
            <form method="post" action="/auth/reset-password" id="resetPasswordForm">
                <input type="hidden" name="__RequestVerificationToken" value="@_token" />
                <input type="hidden" name="email" value="@ObtenerEmail()" />
                <input type="hidden" name="token" value="@ObtenerToken()" />

                <div class="auth-form">
                    <div class="auth-field">
                        <label for="password">Nueva contraseña</label>
                        <input id="password"
                               name="password"
                               class="auth-input"
                               type="password"
                               autocomplete="new-password"
                               minlength="8"
                               required />
                    </div>

                    <div class="auth-field">
                        <label for="confirmPassword">Confirmar nueva contraseña</label>
                        <input id="confirmPassword"
                               name="confirmPassword"
                               class="auth-input"
                               type="password"
                               autocomplete="new-password"
                               minlength="8"
                               required />
                    </div>

                    <div class="auth-password-rules">
                        <div class="auth-password-rules__title">La contraseña debe cumplir:</div>
                        <ul>
                            <li>Mínimo 8 caracteres</li>
                            <li>Una letra mayúscula</li>
                            <li>Una letra minúscula</li>
                            <li>Un número</li>
                            <li>Un símbolo o carácter especial</li>
                        </ul>
                    </div>

                    <button type="submit" class="auth-btn">
                        Cambiar contraseña
                    </button>
                </div>
            </form>
        }

        <div class="auth-footer">
            <a href="/login">Volver al inicio de sesión</a>
        </div>
    </div>
</div>

@code {
    private string _token = string.Empty;

    protected override void OnInitialized()
    {
        var httpContext = HttpContextAccessor.HttpContext;
        if (httpContext is not null)
        {
            var tokens = Antiforgery.GetAndStoreTokens(httpContext);
            _token = tokens.RequestToken ?? string.Empty;
        }
    }

    private bool DatosInvalidos()
    {
        return string.IsNullOrWhiteSpace(ObtenerEmail()) || string.IsNullOrWhiteSpace(ObtenerToken());
    }

    private string ObtenerEmail()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        return query.TryGetValue("email", out var email) ? email.ToString() : string.Empty;
    }

    private string ObtenerToken()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        return query.TryGetValue("token", out var token) ? token.ToString() : string.Empty;
    }

    private string ObtenerError()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        return query.TryGetValue("error", out var error) ? error.ToString() : string.Empty;
    }
}
