@page "/forgot-password"
@page "/auth/forgot-password"

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using System.ComponentModel.DataAnnotations
@using System.Text
@using TankDesigner.Web.Data
@using TankDesigner.Web.Services

@attribute [AllowAnonymous]

@inject UserManager<ApplicationUser> UserManager
@inject EmailService EmailService
@inject NavigationManager NavigationManager
@inject ILogger<ForgotPassword> Logger

<PageTitle>Recuperar contraseña</PageTitle>

<div class="auth-page">
    <div class="auth-card auth-card--recovery">
        <div class="auth-card__header">
            <div class="auth-kicker">Acceso seguro</div>
            <h1>Recuperar contraseña</h1>
            <p>Introduce el correo de tu cuenta y te enviaremos un enlace seguro para crear una nueva contraseña.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(Mensaje))
        {
            <div class="@ClaseMensaje">@Mensaje</div>
        }

        <EditForm Model="_model" OnValidSubmit="EnviarEnlaceAsync">
            <DataAnnotationsValidator />

            <div class="auth-form">
                <div class="auth-field">
                    <label for="email">Correo electrónico</label>
                    <InputText id="email"
                               class="auth-input"
                               @bind-Value="_model.Email"
                               placeholder="correo@ejemplo.com"
                               autocomplete="email" />
                    <ValidationMessage For="@(() => _model.Email)" />
                </div>

                <button type="submit" class="auth-btn auth-btn--primary" disabled="@_enviando">
                    @(_enviando ? "Enviando enlace..." : "Enviar enlace de recuperación")
                </button>
            </div>
        </EditForm>

        <div class="auth-footer auth-footer--center">
            <a href="/login">Volver al inicio de sesión</a>
        </div>
    </div>
</div>

@code {
    private readonly ForgotPasswordModel _model = new();

    private bool _enviando;
    private string? Mensaje;
    private string ClaseMensaje = "auth-alert auth-alert--ok";

    private async Task EnviarEnlaceAsync()
    {
        _enviando = true;
        Mensaje = null;

        try
        {
            var email = _model.Email.Trim().ToLowerInvariant();
            var usuario = await UserManager.FindByEmailAsync(email);

            if (usuario is not null)
            {
                var token = await UserManager.GeneratePasswordResetTokenAsync(usuario);
                var tokenCodificado = WebEncoders.Base64UrlEncode(Encoding.UTF8.GetBytes(token));

                var url = NavigationManager.ToAbsoluteUri(
                    $"/reset-password?email={Uri.EscapeDataString(email)}&token={Uri.EscapeDataString(tokenCodificado)}"
                ).ToString();

                var cuerpo = $@"
                    <div style=""font-family:Arial,sans-serif;max-width:620px;margin:auto;color:#0f172a;"">
                        <h2>Recuperación de contraseña</h2>
                        <p>Has solicitado restablecer la contraseña de tu cuenta en <strong>Tank Structural Designer</strong>.</p>
                        <p>Para crear una nueva contraseña, pulsa el siguiente botón:</p>
                        <p style=""margin:28px 0;"">
                            <a href=""{url}"" style=""background:#0f172a;color:#ffffff;padding:12px 18px;border-radius:10px;text-decoration:none;font-weight:700;"">
                                Restablecer contraseña
                            </a>
                        </p>
                        <p>Si no has solicitado este cambio, puedes ignorar este correo.</p>
                    </div>";

                await EmailService.EnviarEmailAsync(
                    email,
                    "Recuperar contraseña - Tank Structural Designer",
                    cuerpo
                );
            }

            Mensaje = "Si el correo existe, recibirás un enlace de recuperación.";
            ClaseMensaje = "auth-alert auth-alert--ok";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "ERROR SMTP RECUPERACION");

            Mensaje = "No se ha podido enviar el correo. Revisa la configuración SMTP.";
            ClaseMensaje = "auth-alert auth-alert--error";
        }
        finally
        {
            _enviando = false;
        }
    }

    private class ForgotPasswordModel
    {
        [Required(ErrorMessage = "Introduce tu correo electrónico.")]
        [EmailAddress(ErrorMessage = "Introduce un correo válido.")]
        public string Email { get; set; } = "";
    }
}