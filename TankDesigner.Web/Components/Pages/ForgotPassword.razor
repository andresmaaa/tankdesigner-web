@page "/forgot-password"
@page "/auth/forgot-password"

@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using System.Text
@using TankDesigner.Web.Data
@using TankDesigner.Web.Services

@inject UserManager<ApplicationUser> UserManager
@inject EmailService EmailService
@inject NavigationManager NavigationManager

<PageTitle>Recuperar contraseña</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-card__header">
            <h1>Recuperar contraseña</h1>
            <p>Introduce tu correo y te enviaremos un enlace seguro para cambiar la contraseña.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(Mensaje))
        {
            <div class="auth-alert auth-alert--info">@Mensaje</div>
        }

        <EditForm Model="_model" OnValidSubmit="EnviarEnlaceAsync">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label>Correo electrónico</label>
                <InputText class="auth-input"
                           @bind-Value="_model.Email"
                           placeholder="correo@ejemplo.com" />
                <ValidationMessage For="@(() => _model.Email)" />
            </div>

            <button type="submit" class="auth-button" disabled="@_enviando">
                @(_enviando ? "Enviando..." : "Enviar enlace")
            </button>
        </EditForm>

        <div class="auth-card__footer">
            <a href="/login">Volver al inicio de sesión</a>
        </div>
    </div>
</div>

@code {
    private readonly Model _model = new();
    private bool _enviando;
    private string? Mensaje;

    private async Task EnviarEnlaceAsync()
    {
        _enviando = true;

        try
        {
            var email = _model.Email.Trim();
            var usuario = await UserManager.FindByEmailAsync(email);

            if (usuario != null)
            {
                var token = await UserManager.GeneratePasswordResetTokenAsync(usuario);

                var tokenCodificado = WebEncoders.Base64UrlEncode(Encoding.UTF8.GetBytes(token));

                var url = NavigationManager.ToAbsoluteUri(
                    $"/auth/reset-password?email={Uri.EscapeDataString(email)}&token={Uri.EscapeDataString(tokenCodificado)}"
                ).ToString();

                await EmailService.EnviarEmailAsync(
                    email,
                    "Recuperar contraseña",
                    $"<p>Pulsa aquí:</p><a href='{url}'>Restablecer contraseña</a>"
                );
            }

            Mensaje = "Si el correo existe, recibirás un enlace.";
        }
        catch (Exception ex)
        {
            Console.WriteLine($"ERROR SMTP: {ex}");
            Mensaje = "Error al enviar el correo.";
        }

        _enviando = false;
    }

    public class Model
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        public string Email { get; set; } = "";
    }
}