@page "/forgot-password"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Antiforgery
@using Microsoft.AspNetCore.Http

@attribute [AllowAnonymous]

@inject NavigationManager NavigationManager
@inject IAntiforgery Antiforgery
@inject IHttpContextAccessor HttpContextAccessor

<PageTitle>Recuperar contraseña</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-card__header">
            <h1>Recuperar contraseña</h1>
            <p>Introduce tu correo y te enviaremos un enlace seguro para crear una nueva contraseña.</p>
        </div>

        @if (SolicitudEnviada())
        {
            <div class="auth-alert auth-alert--ok">
                Si existe una cuenta con ese correo, recibirás un enlace para restablecer la contraseña.
            </div>
        }

        @if (MostrarError())
        {
            <div class="auth-alert auth-alert--error">
                No se ha podido enviar el correo de recuperación. Revisa la configuración SMTP.
            </div>
        }

        <form method="post" action="/auth/forgot-password">
            <input type="hidden" name="__RequestVerificationToken" value="@_token" />

            <div class="auth-form">
                <div class="auth-field">
                    <label for="email">Correo electrónico</label>
                    <input id="email"
                           name="email"
                           class="auth-input"
                           type="email"
                           value="@ObtenerEmailInicial()"
                           inputmode="email"
                           autocomplete="username"
                           autocapitalize="off"
                           spellcheck="false"
                           required />
                </div>

                <button type="submit" class="auth-btn">
                    Enviar enlace de recuperación
                </button>
            </div>
        </form>

        <div class="auth-footer">
            ¿Ya recuerdas tu contraseña?
            <a href="/login">Volver al inicio de sesión</a>
        </div>
    </div>
</div>

@code {
    private string _token = string.Empty;

    protected override void OnInitialized()
    {
        var httpContext = HttpContextAccessor.HttpContext;
        if (httpContext is not null)
        {
            var tokens = Antiforgery.GetAndStoreTokens(httpContext);
            _token = tokens.RequestToken ?? string.Empty;
        }
    }

    private bool SolicitudEnviada()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        return query.ContainsKey("sent");
    }

    private bool MostrarError()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        return query.ContainsKey("error");
    }

    private string ObtenerEmailInicial()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        return query.TryGetValue("email", out var email) ? email.ToString() : string.Empty;
    }
}
