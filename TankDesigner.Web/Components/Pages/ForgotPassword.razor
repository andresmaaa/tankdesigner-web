@page "/forgot-password"
@page "/auth/forgot-password"

@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using System.Text
@using TankDesigner.Web.Data
@using TankDesigner.Web.Services

@inject UserManager<ApplicationUser> UserManager
@inject EmailService EmailService
@inject NavigationManager NavigationManager

<PageTitle>Recuperar contraseña</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-card__header">
            <h1>Recuperar contraseña</h1>
            <p>Introduce tu correo y te enviaremos un enlace seguro para cambiar la contraseña.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(Mensaje))
        {
            <div class="@ClaseMensaje">@Mensaje</div>
        }

        <EditForm Model="_model" OnValidSubmit="EnviarEnlaceAsync">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label for="email">Correo electrónico</label>
                <InputText id="email"
                           class="form-control"
                           @bind-Value="_model.Email"
                           autocomplete="email"
                           placeholder="correo@ejemplo.com" />
                <ValidationMessage For="@(() => _model.Email)" />
            </div>

            <button type="submit" class="auth-button" disabled="@_enviando">
                @(_enviando ? "Enviando..." : "Enviar enlace de recuperación")
            </button>
        </EditForm>

        <div class="auth-card__footer">
            <a href="/login">Volver al inicio de sesión</a>
        </div>
    </div>
</div>

@code {
    private readonly ForgotPasswordModel _model = new();

    private bool _enviando;
    private string? Mensaje;
    private string ClaseMensaje = "auth-alert auth-alert--info";

    private async Task EnviarEnlaceAsync()
    {
        _enviando = true;
        Mensaje = null;

        try
        {
            var email = _model.Email.Trim();

            var usuario = await UserManager.FindByEmailAsync(email);

            // Por seguridad, nunca digo si el correo existe o no.
            if (usuario == null)
            {
                Mensaje = "Si el correo existe, recibirás un enlace de recuperación.";
                ClaseMensaje = "auth-alert auth-alert--success";
                return;
            }

            var token = await UserManager.GeneratePasswordResetTokenAsync(usuario);

            var tokenCodificado = WebEncoders.Base64UrlEncode(Encoding.UTF8.GetBytes(token));

            var url = NavigationManager.ToAbsoluteUri(
                $"/auth/reset-password?email={Uri.EscapeDataString(email)}&token={Uri.EscapeDataString(tokenCodificado)}"
            ).ToString();

            var cuerpo = $@"
                <h2>Recuperación de contraseña</h2>
                <p>Has solicitado restablecer la contraseña de tu cuenta en Tank Structural Designer.</p>
                <p>Pulsa en el siguiente enlace para crear una nueva contraseña:</p>
                <p><a href=""{url}"">Restablecer contraseña</a></p>
                <p>Si no has solicitado este cambio, puedes ignorar este correo.</p>";

            await EmailService.EnviarEmailAsync(
                email,
                "Recuperar contraseña - Tank Structural Designer",
                cuerpo
            );

            Mensaje = "Si el correo existe, recibirás un enlace de recuperación.";
            ClaseMensaje = "auth-alert auth-alert--success";
        }
        catch (Exception ex)
        {
            Console.WriteLine($"ERROR SMTP RECUPERACION: {ex}");

            Mensaje = "No se ha podido enviar el correo. Revisa la configuración SMTP.";
            ClaseMensaje = "auth-alert auth-alert--error";
        }
        finally
        {
            _enviando = false;
        }
    }

    public class ForgotPasswordModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Introduce tu correo electrónico.")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Introduce un correo válido.")]
        public string Email { get; set; } = "";
    }
}