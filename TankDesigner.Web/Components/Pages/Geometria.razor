@page "/geometria"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using System.Globalization
@using TankDesigner.Web.Services
@using TankDesigner.Core.Services
@inject ProyectoState EstadoProyecto
@inject OpcionesFormularioService Opciones
@inject CalculoGeometriaService CalculoGeometriaService
@inject FormularioValidacionService ValidacionService

<PageTitle>Geometría</PageTitle>

<div class="geometria-page">
    <div class="page-header">
        <h1>Geometría</h1>
        <p>Configuración geométrica base del depósito y parámetros constructivos principales.</p>
    </div>

    @if (_errores.Count > 0)
    {
        <div class="alert-box">
            <div class="alert-box__title">Hay datos de geometría que conviene revisar</div>
            <ul>
                @foreach (var error in _errores)
                {
                    <li>@error</li>
                }
            </ul>
        </div>
    }

    <EditForm Model="EstadoProyecto.Tanque">
        <div class="page-layout">
            <section class="main-column">
                <article class="td-panel">
                    <div class="td-panel__header">
                        <div class="section-kicker">Bloque 01</div>
                        <h2>Configuración constructiva</h2>
                        <p>Parámetros principales necesarios para construir el modelo base del depósito.</p>
                    </div>

                    <div class="form-grid">
                        <div class="field">
                            <label>Número de chapas por anillo</label>
                            <input class="td-input"
                                   type="number"
                                   min="1"
                                   step="1"
                                   value="@EstadoProyecto.Tanque.ChapasPorAnillo"
                                   @oninput="OnChapasPorAnilloInput" />
                            <small>Cantidad de planchas que forman cada anillo.</small>
                        </div>

                        <div class="field">
                            <label>Número de anillos</label>
                            <input class="td-input"
                                   type="number"
                                   min="1"
                                   step="1"
                                   value="@EstadoProyecto.Tanque.NumeroAnillos"
                                   @oninput="OnNumeroAnillosInput" />
                            <small>Número total de anillos del tanque.</small>
                        </div>

                        <div class="field">
                            <label>Anillo de arranque F</label>
                            <select class="td-input td-select" value="@EstadoProyecto.Tanque.AnilloArranque" @onchange="OnAnilloArranqueChange">
                                @foreach (var item in _anillosArranque)
                                {
                                    <option value="@item">@item</option>
                                }
                            </select>
                            <small>Posición seleccionada para el anillo de arranque.</small>
                        </div>

                        <div class="field">
                            <label>Borde libre (mm)</label>
                            <input class="td-input"
                                   type="number"
                                   min="0"
                                   step="1"
                                   value="@FormatearNumero(EstadoProyecto.Tanque.BordeLibre)"
                                   @oninput="OnBordeLibreInput" />
                            <small>Separación libre prevista en la parte superior.</small>
                        </div>

                        <div class="field">
                            <label>Densidad del líquido</label>
                            <input class="td-input"
                                   type="number"
                                   min="0"
                                   step="0.1"
                                   value="@FormatearNumero(EstadoProyecto.Tanque.DensidadLiquido)"
                                   @oninput="OnDensidadLiquidoInput" />
                            <small>Densidad relativa del fluido contenido.</small>
                        </div>

                        <div class="field">
                            <label>Tipo de techo</label>
                            <select class="td-input td-select" value="@EstadoProyecto.Instalacion.TipoTecho" @onchange="OnTipoTechoChange">
                                @foreach (var item in _tiposTecho)
                                {
                                    <option value="@item">@item</option>
                                }
                            </select>
                            <small>Configuración general de cubierta vinculada al modelo geométrico.</small>
                        </div>

                        <div class="field">
                            <label>Tipo anillo</label>
                            <select class="td-input td-select" value="@EstadoProyecto.Instalacion.TipoMedioAnillo" @onchange="OnTipoMedioAnilloChange">
                                @foreach (var item in _tiposMedioAnillo)
                                {
                                    <option value="@item">@item</option>
                                }
                            </select>
                            <small>Configuración auxiliar del anillo asociada al tanque.</small>
                        </div>
                    </div>
                </article>

                <article class="td-panel">
                    <div class="td-panel__header">
                        <div class="section-kicker">Bloque 02</div>
                        <h2>Datos reales por anillo</h2>
                        <p>Aquí puedes definir la altura, material y configuración de cada anillo. Si dejas la configuración en automática, el cálculo elegirá la válida del catálogo.</p>
                    </div>

                    <div style="overflow-x:auto;">
                        <table class="td-table" style="width:100%; border-collapse:separate; border-spacing:0 10px;">
                            <thead>
                                <tr>
                                    <th style="text-align:left;">Anillo</th>
                                    <th style="text-align:left;">Altura (mm)</th>
                                    <th style="text-align:left;">Material</th>
                                    <th style="text-align:left;">Configuración</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < EstadoProyecto.Tanque.NumeroAnillos; i++)
                                {
                                    var index = i;
                                    <tr>
                                        <td style="padding:6px 8px;">@(index + 1)</td>
                                        <td style="padding:6px 8px; min-width:140px;">
                                            <input class="td-input"
                                                   type="number"
                                                   min="1"
                                                   step="1"
                                                   value="@FormatearNumero(ObtenerAlturaAnillo(index))"
                                                   @oninput="e => OnAlturaAnilloInput(index, e)" />
                                        </td>
                                        <td style="padding:6px 8px; min-width:180px;">
                                            <select class="td-input td-select"
                                                    value="@ObtenerMaterialAnillo(index)"
                                                    @onchange="e => OnMaterialAnilloChange(index, e)">
                                                @foreach (var item in _materiales)
                                                {
                                                    <option value="@item">@item</option>
                                                }
                                            </select>
                                        </td>
                                        <td style="padding:6px 8px; min-width:220px;">
                                            <select class="td-input td-select"
                                                    value="@ObtenerConfiguracionAnillo(index)"
                                                    @onchange="e => OnConfiguracionAnilloChange(index, e)">
                                                <option value="">Automática</option>
                                                @foreach (var item in _configuraciones)
                                                {
                                                    <option value="@item">@item</option>
                                                }
                                            </select>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </article>

                <article class="td-panel">
                    <div class="td-panel__header">
                        <div class="section-kicker">Bloque 03</div>
                        <h2>Resultados geométricos</h2>
                        <p>Magnitudes obtenidas automáticamente a partir de la configuración seleccionada.</p>
                    </div>

                    <div class="results-grid">
                        <div class="result-card">
                            <span class="result-card__label">Diámetro calculado</span>
                            <strong class="result-card__value">@ValorSeguro(EstadoProyecto.Tanque.Diametro)</strong>
                            <small>mm</small>
                        </div>

                        <div class="result-card">
                            <span class="result-card__label">Altura total calculada</span>
                            <strong class="result-card__value">@ValorSeguro(EstadoProyecto.Tanque.AlturaTotal)</strong>
                            <small>mm</small>
                        </div>

                        <div class="result-card">
                            <span class="result-card__label">Altura panel base</span>
                            <strong class="result-card__value">@ValorSeguro(EstadoProyecto.Tanque.AlturaPanelBase)</strong>
                            <small>mm</small>
                        </div>

                        <div class="result-card">
                            <span class="result-card__label">Número total de chapas</span>
                            <strong class="result-card__value">@EstadoProyecto.Tanque.NumeroTotalChapas</strong>
                            <small>uds</small>
                        </div>
                    </div>
                </article>
            </section>

            <aside class="side-column">
                <article class="td-panel td-panel--compact td-panel--sticky">
                    <div class="td-panel__header">
                        <div class="section-kicker">Resumen vivo</div>
                        <h2>Configuración base</h2>
                        <p>Resumen inmediato del estado geométrico actual del tanque.</p>
                    </div>

                    <div class="summary-list">
                        <div class="summary-row">
                            <span class="summary-row__label">Modelo geométrico</span>
                            <span class="summary-row__value">@TextoSeguro(EstadoProyecto.Tanque.Modelo)</span>
                        </div>
                        <div class="summary-row">
                            <span class="summary-row__label">Tipo de techo</span>
                            <span class="summary-row__value">@TextoSeguro(EstadoProyecto.Instalacion.TipoTecho)</span>
                        </div>
                        <div class="summary-row">
                            <span class="summary-row__label">Tipo anillo</span>
                            <span class="summary-row__value">@TextoSeguro(EstadoProyecto.Instalacion.TipoMedioAnillo)</span>
                        </div>
                        <div class="summary-row">
                            <span class="summary-row__label">Materiales aplicados</span>
                            <span class="summary-row__value">@ObtenerResumenMateriales()</span>
                        </div>
                        <div class="summary-row">
                            <span class="summary-row__label">Configuraciones aplicadas</span>
                            <span class="summary-row__value">@ObtenerResumenConfiguraciones()</span>
                        </div>
                        <div class="summary-row">
                            <span class="summary-row__label">Diámetro calculado</span>
                            <span class="summary-row__value">@ValorSeguro(EstadoProyecto.Tanque.Diametro)</span>
                        </div>
                        <div class="summary-row">
                            <span class="summary-row__label">Altura total calculada</span>
                            <span class="summary-row__value">@ValorSeguro(EstadoProyecto.Tanque.AlturaTotal)</span>
                        </div>
                        <div class="summary-row">
                            <span class="summary-row__label">Altura panel base</span>
                            <span class="summary-row__value">@ValorSeguro(EstadoProyecto.Tanque.AlturaPanelBase)</span>
                        </div>
                        <div class="summary-row">
                            <span class="summary-row__label">Número total de chapas</span>
                            <span class="summary-row__value">@EstadoProyecto.Tanque.NumeroTotalChapas</span>
                        </div>
                    </div>
                </article>
            </aside>
        </div>
    </EditForm>
</div>

@code {
    private List<int> _anillosArranque = new();
    private List<string> _tiposMedioAnillo = new();
    private List<string> _tiposTecho = new();
    private List<string> _materiales = new();
    private List<string> _configuraciones = new();
    private List<string> _errores = new();

    protected override void OnInitialized()
    {
        _anillosArranque = Opciones.ObtenerAnillosArranque();
        _tiposMedioAnillo = Opciones.ObtenerTiposMedioAnillo();
        _tiposTecho = Opciones.ObtenerTiposTechoInstalacion();
        _materiales = Opciones.ObtenerMateriales();

        CargarConfiguraciones();
        AplicarValoresPorDefecto();
        SincronizarDatosPorAnillo();
        RecalcularYValidar();
    }

    protected override void OnParametersSet()
    {
        CargarConfiguraciones();
        SincronizarDatosPorAnillo();
        RecalcularYValidar();
    }

    private void AplicarValoresPorDefecto()
    {
        if (EstadoProyecto.Tanque.ChapasPorAnillo <= 0)
            EstadoProyecto.Tanque.ChapasPorAnillo = 16;

        if (EstadoProyecto.Tanque.NumeroAnillos <= 0)
            EstadoProyecto.Tanque.NumeroAnillos = 6;

        if (EstadoProyecto.Tanque.AnilloArranque <= 0)
            EstadoProyecto.Tanque.AnilloArranque = _anillosArranque.FirstOrDefault();

        if (EstadoProyecto.Tanque.BordeLibre <= 0)
            EstadoProyecto.Tanque.BordeLibre = 300;

        if (EstadoProyecto.Tanque.DensidadLiquido <= 0)
            EstadoProyecto.Tanque.DensidadLiquido = 1;

        if (string.IsNullOrWhiteSpace(EstadoProyecto.Instalacion.TipoMedioAnillo))
            EstadoProyecto.Instalacion.TipoMedioAnillo = "Anillo entero";

        if (string.IsNullOrWhiteSpace(EstadoProyecto.Instalacion.TipoTecho))
            EstadoProyecto.Instalacion.TipoTecho = "Sin techo";

        if (string.IsNullOrWhiteSpace(EstadoProyecto.Cargas.RoofType))
            EstadoProyecto.Cargas.RoofType = EstadoProyecto.Instalacion.TipoTecho.Equals("Sin techo", StringComparison.OrdinalIgnoreCase)
                ? "None"
                : EstadoProyecto.Instalacion.TipoTecho;
    }

    private void CargarConfiguraciones()
    {
        _configuraciones = Opciones.ObtenerModelosPorFabricante(EstadoProyecto.Proyecto.Fabricante ?? string.Empty);
        _configuraciones ??= new List<string>();
    }

    private void SincronizarDatosPorAnillo()
    {
        EstadoProyecto.Tanque.AlturasAnillos ??= new List<double>();
        EstadoProyecto.Tanque.MaterialesAnillos ??= new List<string>();
        EstadoProyecto.Tanque.ConfiguracionesAnillos ??= new List<string>();

        string materialDefault = !string.IsNullOrWhiteSpace(EstadoProyecto.Proyecto.MaterialPrincipal)
            ? EstadoProyecto.Proyecto.MaterialPrincipal.Trim()
            : (_materiales.FirstOrDefault() ?? "S235");

        while (EstadoProyecto.Tanque.AlturasAnillos.Count < EstadoProyecto.Tanque.NumeroAnillos)
            EstadoProyecto.Tanque.AlturasAnillos.Add(EstadoProyecto.Tanque.AlturaPanelBase > 0 ? EstadoProyecto.Tanque.AlturaPanelBase : 1200);

        while (EstadoProyecto.Tanque.MaterialesAnillos.Count < EstadoProyecto.Tanque.NumeroAnillos)
            EstadoProyecto.Tanque.MaterialesAnillos.Add(materialDefault);

        while (EstadoProyecto.Tanque.ConfiguracionesAnillos.Count < EstadoProyecto.Tanque.NumeroAnillos)
            EstadoProyecto.Tanque.ConfiguracionesAnillos.Add(string.Empty);

        if (EstadoProyecto.Tanque.AlturasAnillos.Count > EstadoProyecto.Tanque.NumeroAnillos)
            EstadoProyecto.Tanque.AlturasAnillos = EstadoProyecto.Tanque.AlturasAnillos.Take(EstadoProyecto.Tanque.NumeroAnillos).ToList();

        if (EstadoProyecto.Tanque.MaterialesAnillos.Count > EstadoProyecto.Tanque.NumeroAnillos)
            EstadoProyecto.Tanque.MaterialesAnillos = EstadoProyecto.Tanque.MaterialesAnillos.Take(EstadoProyecto.Tanque.NumeroAnillos).ToList();

        if (EstadoProyecto.Tanque.ConfiguracionesAnillos.Count > EstadoProyecto.Tanque.NumeroAnillos)
            EstadoProyecto.Tanque.ConfiguracionesAnillos = EstadoProyecto.Tanque.ConfiguracionesAnillos.Take(EstadoProyecto.Tanque.NumeroAnillos).ToList();

        for (int i = 0; i < EstadoProyecto.Tanque.NumeroAnillos; i++)
        {
            if (EstadoProyecto.Tanque.AlturasAnillos[i] <= 0)
                EstadoProyecto.Tanque.AlturasAnillos[i] = EstadoProyecto.Tanque.AlturaPanelBase > 0 ? EstadoProyecto.Tanque.AlturaPanelBase : 1200;

            if (string.IsNullOrWhiteSpace(EstadoProyecto.Tanque.MaterialesAnillos[i]))
                EstadoProyecto.Tanque.MaterialesAnillos[i] = materialDefault;

            EstadoProyecto.Tanque.MaterialesAnillos[i] = EstadoProyecto.Tanque.MaterialesAnillos[i].Trim();
            EstadoProyecto.Tanque.ConfiguracionesAnillos[i] = (EstadoProyecto.Tanque.ConfiguracionesAnillos[i] ?? string.Empty).Trim();
        }
    }

    private void OnChapasPorAnilloInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int valor))
        {
            EstadoProyecto.Tanque.ChapasPorAnillo = Math.Max(1, valor);
            RecalcularYValidar();
        }
    }

    private void OnNumeroAnillosInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int valor))
        {
            EstadoProyecto.Tanque.NumeroAnillos = Math.Max(1, valor);

            if (EstadoProyecto.Tanque.AnilloArranque > EstadoProyecto.Tanque.NumeroAnillos)
                EstadoProyecto.Tanque.AnilloArranque = EstadoProyecto.Tanque.NumeroAnillos;

            SincronizarDatosPorAnillo();
            RecalcularYValidar();
        }
    }

    private void OnAnilloArranqueChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int valor))
            EstadoProyecto.Tanque.AnilloArranque = valor;

        RecalcularYValidar();
    }

    private void OnBordeLibreInput(ChangeEventArgs e)
    {
        EstadoProyecto.Tanque.BordeLibre = ParseDoubleOrZero(e.Value?.ToString());
        RecalcularYValidar();
    }

    private void OnDensidadLiquidoInput(ChangeEventArgs e)
    {
        EstadoProyecto.Tanque.DensidadLiquido = ParseDoubleOrZero(e.Value?.ToString());

        if (EstadoProyecto.Tanque.DensidadLiquido > 0)
            EstadoProyecto.Cargas.DensidadLiquido = EstadoProyecto.Tanque.DensidadLiquido;

        RecalcularYValidar();
    }

    private void OnTipoTechoChange(ChangeEventArgs e)
    {
        EstadoProyecto.Instalacion.TipoTecho = e.Value?.ToString() ?? "Sin techo";

        if (string.IsNullOrWhiteSpace(EstadoProyecto.Instalacion.TipoTecho) ||
            EstadoProyecto.Instalacion.TipoTecho.Equals("Sin techo", StringComparison.OrdinalIgnoreCase))
        {
            EstadoProyecto.Cargas.RoofType = "None";
            EstadoProyecto.Cargas.RoofDeadLoad = 0;
            EstadoProyecto.Cargas.RoofSnowLoad = 0;
            EstadoProyecto.Cargas.RoofLiveLoad = 0;
            EstadoProyecto.Cargas.RoofCentroid = 0;
            EstadoProyecto.Cargas.RoofProjectedArea = 0;
            EstadoProyecto.Cargas.RoofAngle = "0°";
        }
        else
        {
            EstadoProyecto.Cargas.RoofType = EstadoProyecto.Instalacion.TipoTecho;
        }

        RecalcularYValidar();
    }

    private void OnTipoMedioAnilloChange(ChangeEventArgs e)
    {
        EstadoProyecto.Instalacion.TipoMedioAnillo = e.Value?.ToString() ?? "Anillo entero";
        RecalcularYValidar();
    }

    private void OnAlturaAnilloInput(int index, ChangeEventArgs e)
    {
        SincronizarDatosPorAnillo();
        EstadoProyecto.Tanque.AlturasAnillos[index] = Math.Max(1, ParseDoubleOrZero(e.Value?.ToString()));
        RecalcularYValidar();
    }

    private void OnMaterialAnilloChange(int index, ChangeEventArgs e)
    {
        SincronizarDatosPorAnillo();
        EstadoProyecto.Tanque.MaterialesAnillos[index] = e.Value?.ToString()?.Trim() ?? string.Empty;
        RecalcularYValidar();
    }

    private void OnConfiguracionAnilloChange(int index, ChangeEventArgs e)
    {
        SincronizarDatosPorAnillo();
        EstadoProyecto.Tanque.ConfiguracionesAnillos[index] = e.Value?.ToString()?.Trim() ?? string.Empty;
        RecalcularYValidar();
    }

    private double ObtenerAlturaAnillo(int index)
    {
        SincronizarDatosPorAnillo();
        return index >= 0 && index < EstadoProyecto.Tanque.AlturasAnillos.Count
            ? EstadoProyecto.Tanque.AlturasAnillos[index]
            : (EstadoProyecto.Tanque.AlturaPanelBase > 0 ? EstadoProyecto.Tanque.AlturaPanelBase : 1200);
    }

    private string ObtenerMaterialAnillo(int index)
    {
        SincronizarDatosPorAnillo();
        return index >= 0 && index < EstadoProyecto.Tanque.MaterialesAnillos.Count
            ? EstadoProyecto.Tanque.MaterialesAnillos[index]
            : (!string.IsNullOrWhiteSpace(EstadoProyecto.Proyecto.MaterialPrincipal) ? EstadoProyecto.Proyecto.MaterialPrincipal.Trim() : "S235");
    }

    private string ObtenerConfiguracionAnillo(int index)
    {
        SincronizarDatosPorAnillo();
        return index >= 0 && index < EstadoProyecto.Tanque.ConfiguracionesAnillos.Count
            ? EstadoProyecto.Tanque.ConfiguracionesAnillos[index]
            : string.Empty;
    }

    private string GenerarModeloAutomatico()
    {
        string letraFabricante = ObtenerLetraFabricante(EstadoProyecto.Proyecto.Fabricante);
        int chapasPorAnillo = Math.Max(0, EstadoProyecto.Tanque.ChapasPorAnillo);
        double numeroAnillosVisible = ObtenerNumeroAnillosVisible();

        if (string.IsNullOrWhiteSpace(letraFabricante) || chapasPorAnillo <= 0 || numeroAnillosVisible <= 0)
            return string.Empty;

        string anillosTexto = numeroAnillosVisible % 1 == 0
            ? ((int)numeroAnillosVisible).ToString(CultureInfo.InvariantCulture)
            : numeroAnillosVisible.ToString("0.0", CultureInfo.InvariantCulture);

        return $"{letraFabricante}{chapasPorAnillo}/{anillosTexto}";
    }

    private double ObtenerNumeroAnillosVisible()
    {
        double numeroAnillos = EstadoProyecto.Tanque.NumeroAnillos;

        if (string.Equals(EstadoProyecto.Instalacion.TipoMedioAnillo, "1/2 anillo", StringComparison.OrdinalIgnoreCase))
            return numeroAnillos + 0.5;

        if (string.Equals(EstadoProyecto.Instalacion.TipoMedioAnillo, "1/4 anillo", StringComparison.OrdinalIgnoreCase))
            return numeroAnillos + 0.25;

        return numeroAnillos;
    }

    private static string ObtenerLetraFabricante(string? fabricante)
    {
        if (string.IsNullOrWhiteSpace(fabricante))
            return string.Empty;

        var valor = fabricante.Trim().ToUpperInvariant();

        if (valor.Contains("BALMORAL"))
            return "B";

        if (valor.Contains("PERMASTORE"))
            return "P";

        if (valor.Contains("DL2"))
            return "D";

        return valor.Substring(0, 1);
    }

    private void RecalcularYValidar()
    {
        SincronizarDatosPorAnillo();

        EstadoProyecto.Tanque.AlturaPanelBase =
            CalculoGeometriaService.ObtenerAlturaPanelBase(EstadoProyecto.Tanque, EstadoProyecto.Proyecto);

        EstadoProyecto.Tanque.AlturaTotal =
            CalculoGeometriaService.ObtenerAlturaTotal(EstadoProyecto.Tanque, EstadoProyecto.Proyecto);

        EstadoProyecto.Tanque.Diametro =
            CalculoGeometriaService.ObtenerDiametro(EstadoProyecto.Tanque, EstadoProyecto.Proyecto);

        EstadoProyecto.Tanque.Modelo = GenerarModeloAutomatico();

        _errores = ValidacionService.ValidarGeometria(EstadoProyecto.Tanque);
        StateHasChanged();
    }

    private string ObtenerResumenMateriales()
    {
        SincronizarDatosPorAnillo();

        var materiales = EstadoProyecto.Tanque.MaterialesAnillos
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Select(x => x.Trim())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(x => x)
            .ToList();

        return materiales.Count > 0 ? string.Join(", ", materiales) : "—";
    }

    private string ObtenerResumenConfiguraciones()
    {
        SincronizarDatosPorAnillo();

        var configuraciones = EstadoProyecto.Tanque.ConfiguracionesAnillos
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Select(x => x.Trim())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(x => x)
            .ToList();

        return configuraciones.Count > 0 ? string.Join(", ", configuraciones) : "Automática";
    }

    private double ParseDoubleOrZero(string? texto)
    {
        if (string.IsNullOrWhiteSpace(texto))
            return 0;

        texto = texto.Replace(',', '.');
        return double.TryParse(texto, NumberStyles.Any, CultureInfo.InvariantCulture, out double valor) ? valor : 0;
    }

    private string FormatearNumero(double valor)
        => valor.ToString("0.##", CultureInfo.InvariantCulture);

    private string ValorSeguro(double valor)
        => valor > 0 ? valor.ToString("0.##", CultureInfo.InvariantCulture) : "—";

    private string TextoSeguro(string? texto)
        => string.IsNullOrWhiteSpace(texto) ? "—" : texto.Trim();
}
