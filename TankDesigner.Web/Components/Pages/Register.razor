@page "/register"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Antiforgery
@using Microsoft.AspNetCore.Http

@attribute [AllowAnonymous]

@inject NavigationManager NavigationManager
@inject IAntiforgery Antiforgery
@inject IHttpContextAccessor HttpContextAccessor

<PageTitle>Crear cuenta</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-card__header">
            <h1>Crear cuenta</h1>
            <p>Crea tu cuenta y entrarás directamente a la aplicación.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(ObtenerError()))
        {
            <div class="auth-alert auth-alert--error">@ObtenerError()</div>
        }

        <form method="post" action="/auth/register">
            <input type="hidden" name="__RequestVerificationToken" value="@_token" />
            <input type="hidden" name="returnUrl" value="@ObtenerReturnUrl()" />
            <input type="hidden" name="token" value="@ObtenerTokenInvitacion()" />

            <div class="auth-form">
                <div class="auth-field">
                    <label for="nombreCompleto">Nombre completo</label>
                    <input id="nombreCompleto"
                           name="nombreCompleto"
                           class="auth-input"
                           type="text"
                           value="@ObtenerNombreInicial()"
                           autocomplete="name"
                           minlength="3"
                           required />
                </div>

                <div class="auth-field">
                    <label for="email">Correo electrónico</label>
                    <input id="email"
                           name="email"
                           class="auth-input"
                           type="email"
                           value="@ObtenerEmailInvitado()"
                           inputmode="email"
                           autocomplete="username"
                           autocapitalize="off"
                           spellcheck="false"
                           readonly="@EmailBloqueadoPorInvitacion()"
                           required />
                </div>

                <div class="auth-field">
                    <label for="password">Contraseña</label>
                    <input id="password"
                           name="password"
                           class="auth-input"
                           type="password"
                           autocomplete="new-password"
                           minlength="8"
                           required />
                    <small class="auth-help">
                        Debe tener al menos 8 caracteres e incluir mayúscula, minúscula, número y símbolo.
                    </small>
                </div>

                <div class="auth-field">
                    <label for="confirmPassword">Confirmar contraseña</label>
                    <input id="confirmPassword"
                           name="confirmPassword"
                           class="auth-input"
                           type="password"
                           autocomplete="new-password"
                           minlength="8"
                           required />
                </div>

                <button type="submit" class="auth-btn">
                    Registrarse
                </button>
            </div>
        </form>

        <div class="auth-footer">
            ¿Ya tienes cuenta?
            <a href="@ObtenerRutaLogin()">Iniciar sesión</a>
        </div>
    </div>
</div>

@code {
    private string _token = string.Empty;

    protected override void OnInitialized()
    {
        var httpContext = HttpContextAccessor.HttpContext;
        if (httpContext is not null)
        {
            var tokens = Antiforgery.GetAndStoreTokens(httpContext);
            _token = tokens.RequestToken ?? string.Empty;
        }
    }

    private string ObtenerError()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("error", out var error))
            return error.ToString();

        return string.Empty;
    }

    private string ObtenerReturnUrl()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("returnUrl", out var returnUrl) && !string.IsNullOrWhiteSpace(returnUrl))
            return returnUrl.ToString();

        return "/mis-proyectos";
    }

    private string ObtenerTokenInvitacion()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("token", out var token))
            return token.ToString();

        return string.Empty;
    }

    private string ObtenerEmailInvitado()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("email", out var email))
            return email.ToString();

        return string.Empty;
    }

    private string ObtenerNombreInicial()
    {
        return string.Empty;
    }

    private bool EmailBloqueadoPorInvitacion()
    {
        return !string.IsNullOrWhiteSpace(ObtenerTokenInvitacion()) &&
               !string.IsNullOrWhiteSpace(ObtenerEmailInvitado());
    }

    private string ObtenerRutaLogin()
    {
        var token = ObtenerTokenInvitacion();
        var email = ObtenerEmailInvitado();

        if (!string.IsNullOrWhiteSpace(token))
            return $"/login?token={Uri.EscapeDataString(token)}&email={Uri.EscapeDataString(email)}";

        return "/login";
    }
}