@page "/register"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Identity
@using TankDesigner.Web.Data
@using TankDesigner.Web.Services

@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject NavigationManager NavigationManager
@inject InvitacionesService InvitacionesService

<PageTitle>Crear cuenta</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-card__header">
            <h1>Crear cuenta</h1>
            <p>Registra un usuario para acceder a las funciones protegidas de la plataforma.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(_mensajeError))
        {
            <div class="auth-alert auth-alert--error">@_mensajeError</div>
        }

        @if (!string.IsNullOrWhiteSpace(_mensajeExito))
        {
            <div class="auth-alert auth-alert--success">@_mensajeExito</div>
        }

        <EditForm Model="_modelo" OnValidSubmit="RegistrarUsuario">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="auth-form">
                <div class="auth-field">
                    <label for="nombreCompleto">Nombre completo</label>
                    <InputText id="nombreCompleto" class="auth-input" @bind-Value="_modelo.NombreCompleto" />
                </div>

                <div class="auth-field">
                    <label for="email">Correo electrónico</label>
                    <InputText id="email" class="auth-input" @bind-Value="_modelo.Email" disabled="@TieneInvitacion()" />
                </div>

                <div class="auth-field">
                    <label for="password">Contraseña</label>
                    <InputText id="password" type="password" class="auth-input" @bind-Value="_modelo.Password" />
                </div>

                <div class="auth-field">
                    <label for="confirmPassword">Confirmar contraseña</label>
                    <InputText id="confirmPassword" type="password" class="auth-input" @bind-Value="_modelo.ConfirmPassword" />
                </div>

                <button type="submit" class="auth-btn" disabled="@_procesando">
                    @(_procesando ? "Creando cuenta..." : "Registrarse")
                </button>
            </div>
        </EditForm>

        <div class="auth-footer">
            ¿Ya tienes cuenta?
            <a href="@ObtenerRutaLogin()">Iniciar sesión</a>
        </div>
    </div>
</div>

@code {
    private RegisterModel _modelo = new();
    private string _mensajeError = string.Empty;
    private string _mensajeExito = string.Empty;
    private bool _procesando;

    protected override void OnInitialized()
    {
        var emailInvitado = ObtenerEmailInvitado();
        if (!string.IsNullOrWhiteSpace(emailInvitado))
        {
            _modelo.Email = emailInvitado;
        }
    }

    private async Task RegistrarUsuario()
    {
        if (_procesando)
            return;

        _mensajeError = string.Empty;
        _mensajeExito = string.Empty;
        _procesando = true;

        try
        {
            var email = (_modelo.Email ?? string.Empty).Trim();
            var nombreCompleto = (_modelo.NombreCompleto ?? string.Empty).Trim();
            var token = ObtenerTokenInvitacion();

            var usuarioExistente = await UserManager.FindByEmailAsync(email);

            if (usuarioExistente != null)
            {
                var tienePassword = await UserManager.HasPasswordAsync(usuarioExistente);

                if (tienePassword)
                {
                    _mensajeError = "Ya existe una cuenta registrada con ese correo electrónico.";
                    return;
                }

                usuarioExistente.UserName = email;
                usuarioExistente.Email = email;
                usuarioExistente.EmailConfirmed = true;
                usuarioExistente.NombreCompleto = nombreCompleto;
                usuarioExistente.TelefonoContacto ??= string.Empty;
                usuarioExistente.Cargo ??= string.Empty;
                usuarioExistente.EmpresaNombre ??= string.Empty;
                usuarioExistente.EmpresaDireccion ??= string.Empty;
                usuarioExistente.EmpresaCiudad ??= string.Empty;
                usuarioExistente.EmpresaProvincia ??= string.Empty;
                usuarioExistente.EmpresaCodigoPostal ??= string.Empty;
                usuarioExistente.EmpresaPais ??= string.Empty;
                usuarioExistente.EmpresaWeb ??= string.Empty;
                usuarioExistente.EmpresaIdentificacionFiscal ??= string.Empty;

                var resultadoUpdate = await UserManager.UpdateAsync(usuarioExistente);
                if (!resultadoUpdate.Succeeded)
                {
                    _mensajeError = string.Join(" ", resultadoUpdate.Errors.Select(e => e.Description));
                    return;
                }

                var resultadoPassword = await UserManager.AddPasswordAsync(usuarioExistente, _modelo.Password);
                if (!resultadoPassword.Succeeded)
                {
                    _mensajeError = string.Join(" ", resultadoPassword.Errors.Select(e => e.Description));
                    return;
                }

                var rolesActuales = await UserManager.GetRolesAsync(usuarioExistente);
                if (!rolesActuales.Contains(RolesAplicacion.Usuario))
                {
                    var resultadoRolExistente = await UserManager.AddToRoleAsync(usuarioExistente, RolesAplicacion.Usuario);
                    if (!resultadoRolExistente.Succeeded)
                    {
                        _mensajeError = "La cuenta existe, pero no se pudo asignar el rol Usuario.";
                        return;
                    }
                }

                if (!string.IsNullOrWhiteSpace(token))
                    await InvitacionesService.AplicarInvitacionPorTokenAsync(usuarioExistente, token);
                else
                    await InvitacionesService.AplicarInvitacionPendienteAsync(usuarioExistente);

                await SignInManager.SignInAsync(usuarioExistente, isPersistent: true);

                _mensajeExito = "Cuenta activada correctamente. Sesión iniciada.";

                await Task.Delay(300);
                NavigationManager.NavigateTo("/mis-proyectos", forceLoad: true);
                return;
            }

            var usuario = new ApplicationUser
            {
                UserName = email,
                Email = email,
                EmailConfirmed = true,
                NombreCompleto = nombreCompleto,
                TelefonoContacto = string.Empty,
                Cargo = string.Empty,
                EmpresaNombre = string.Empty,
                EmpresaDireccion = string.Empty,
                EmpresaCiudad = string.Empty,
                EmpresaProvincia = string.Empty,
                EmpresaCodigoPostal = string.Empty,
                EmpresaPais = string.Empty,
                EmpresaWeb = string.Empty,
                EmpresaIdentificacionFiscal = string.Empty
            };

            var resultado = await UserManager.CreateAsync(usuario, _modelo.Password);

            if (!resultado.Succeeded)
            {
                _mensajeError = string.Join(" ", resultado.Errors.Select(e => e.Description));
                return;
            }

            var resultadoRol = await UserManager.AddToRoleAsync(usuario, RolesAplicacion.Usuario);

            if (!resultadoRol.Succeeded)
            {
                _mensajeError = "La cuenta se creó, pero no se pudo asignar el rol Usuario.";
                return;
            }

            if (!string.IsNullOrWhiteSpace(token))
                await InvitacionesService.AplicarInvitacionPorTokenAsync(usuario, token);
            else
                await InvitacionesService.AplicarInvitacionPendienteAsync(usuario);

            await SignInManager.SignInAsync(usuario, isPersistent: true);

            _mensajeExito = "Cuenta creada correctamente. Sesión iniciada.";

            await Task.Delay(300);
            NavigationManager.NavigateTo("/mis-proyectos", forceLoad: true);
        }
        catch (Exception ex)
        {
            _mensajeError = $"No se pudo registrar el usuario: {ex.Message}";
        }
        finally
        {
            _procesando = false;
        }
    }

    private bool TieneInvitacion()
    {
        return !string.IsNullOrWhiteSpace(ObtenerTokenInvitacion());
    }

    private string ObtenerTokenInvitacion()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("token", out var token))
            return token.ToString();

        return string.Empty;
    }

    private string ObtenerEmailInvitado()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("email", out var email))
            return email.ToString();

        return string.Empty;
    }

    private string ObtenerRutaLogin()
    {
        var token = ObtenerTokenInvitacion();
        var email = ObtenerEmailInvitado();

        if (!string.IsNullOrWhiteSpace(token))
            return $"/login?token={Uri.EscapeDataString(token)}&email={Uri.EscapeDataString(email)}";

        return "/login";
    }

    private sealed class RegisterModel
    {
        [Required(ErrorMessage = "El nombre completo es obligatorio.")]
        [MinLength(3, ErrorMessage = "Introduce un nombre válido.")]
        public string NombreCompleto { get; set; } = string.Empty;

        [Required(ErrorMessage = "El correo es obligatorio.")]
        [EmailAddress(ErrorMessage = "Introduce un correo válido.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "La contraseña es obligatoria.")]
        [MinLength(6, ErrorMessage = "La contraseña debe tener al menos 6 caracteres.")]
        public string Password { get; set; } = string.Empty;

        [Required(ErrorMessage = "Debes confirmar la contraseña.")]
        [Compare(nameof(Password), ErrorMessage = "Las contraseñas no coinciden.")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}