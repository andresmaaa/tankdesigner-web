    private async Task DescargarInformeResumenPdfAsync()
    {
        try
        {
            _mensaje = "";

            if (!await UsuarioAutenticadoAsync())
            {
                NavigationManager.NavigateTo("/login?returnUrl=%2Fmis-proyectos", forceLoad: true);
                return;
            }

            if (!ValidarSeleccionInformeResumen())
                return;

            var html = ConstruirHtmlInformeResumen();
            var pdf = await PdfRenderService.GenerarPdfDesdeHtmlAsync(html);
            var base64 = Convert.ToBase64String(pdf);

            var resultado = await JS.InvokeAsync<ResultadoGuardadoJs>(
                "tankInformes.saveFileFromBytes",
                $"resumen-presupuestos-{DateTime.Now:yyyyMMdd-HHmm}.pdf",
                "application/pdf",
                base64);

            if (!resultado.Ok && !resultado.Cancelled)
                _mensaje = resultado.Message ?? "No se pudo guardar el PDF del informe resumen.";
        }
        catch (Exception ex)
        {
            _mensaje = $"Error al descargar el PDF del informe resumen: {ex.Message}";
        }
