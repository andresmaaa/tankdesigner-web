@code {
    private List<ProyectoEntidad> _misProyectos = new();
    private List<ProyectoAdminDto> _todosLosProyectos = new();
    private List<UsuarioAdminDto> _usuarios = new();

    private string _mensaje = "";
    private string _modoActivo = "mis";

    private bool _esAdmin;
    private bool _esSuperAdmin;
    private ApplicationUser? _usuarioActual;

    private string _busquedaMisProyectos = "";
    private string _busquedaTodosLosProyectos = "";
    private string _busquedaUsuarios = "";

    private string _correoInvitacion = "";
    private string _rolInvitacion = "Admin";
    private string _enlaceInvitacionGenerado = "";

    private bool _modoSeleccionInformes;
    private readonly HashSet<int> _proyectosSeleccionados = new();

    protected override async Task OnInitializedAsync()
    {
        await CargarTodoAsync();
    }

    private async Task CargarTodoAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _usuarioActual = await UserManager.GetUserAsync(authState.User);

        if (_usuarioActual == null)
        {
            NavigationManager.NavigateTo("/login?returnUrl=%2Fmis-proyectos", forceLoad: true);
            return;
        }

        _esAdmin = await UserManager.IsInRoleAsync(_usuarioActual, RolesAplicacion.Admin);
        _esSuperAdmin = await UserManager.IsInRoleAsync(_usuarioActual, RolesAplicacion.SuperAdmin);

        _misProyectos = await ProyectoPersistenciaService.ObtenerListaAsync(_usuarioActual.Id);

        if (_esAdmin)
        {
            _todosLosProyectos = await AdminService.ObtenerTodosLosProyectosAsync();
            _usuarios = await AdminService.ObtenerUsuariosAsync();
        }
        else
        {
            _todosLosProyectos = new();
            _usuarios = new();
        }
    }

    private IEnumerable<ProyectoEntidad> MisProyectosFiltrados =>
        _misProyectos.Where(p =>
            CoincideBusqueda(_busquedaMisProyectos, p.Nombre, p.Cliente, p.Normativa, p.Fabricante));

    private IEnumerable<ProyectoAdminDto> TodosLosProyectosFiltrados =>
        _todosLosProyectos.Where(p =>
            CoincideBusqueda(_busquedaTodosLosProyectos, p.Nombre, p.Cliente, p.Normativa, p.Fabricante, p.EmailUsuario));

    private IEnumerable<UsuarioAdminDto> UsuariosFiltrados =>
        _usuarios.Where(u =>
            CoincideBusqueda(
                _busquedaUsuarios,
                u.Email,
                u.NombreCompleto,
                u.EsSuperAdmin ? "SuperAdmin" : u.EsAdmin ? "Admin" : "Usuario"));

    private static bool CoincideBusqueda(string textoBusqueda, params string?[] valores)
    {
        if (string.IsNullOrWhiteSpace(textoBusqueda))
            return true;

        var busqueda = textoBusqueda.Trim();

        return valores.Any(v =>
            !string.IsNullOrWhiteSpace(v) &&
            v.Contains(busqueda, StringComparison.OrdinalIgnoreCase));
    }

    private void CambiarModo(string modo)
    {
        if (!_esAdmin && modo != "mis")
            return;

        _modoActivo = modo;
        _mensaje = "";
    }

    private string ClaseModo(string modo)
    {
        return _modoActivo == modo ? "tab-btn tab-btn--active" : "tab-btn";
    }

    private void LimpiarBusquedaMisProyectos() => _busquedaMisProyectos = "";
    private void LimpiarBusquedaTodosLosProyectos() => _busquedaTodosLosProyectos = "";
    private void LimpiarBusquedaUsuarios() => _busquedaUsuarios = "";

    private void ActivarModoSeleccionInformes()
    {
        _modoSeleccionInformes = true;
        _mensaje = "";
    }

    private void CancelarModoSeleccionInformes()
    {
        _modoSeleccionInformes = false;
        _proyectosSeleccionados.Clear();
        _mensaje = "";
    }

    private void SeleccionarTodosInformes()
    {
        _proyectosSeleccionados.Clear();

        foreach (var proyecto in MisProyectosFiltrados)
        {
            _proyectosSeleccionados.Add(proyecto.Id);
        }

        _mensaje = $"{_proyectosSeleccionados.Count} proyecto(s) preparado(s) para el informe resumen.";
    }

    private void LimpiarSeleccionInformes()
    {
        _proyectosSeleccionados.Clear();
        _mensaje = "Selección de informes limpiada.";
    }

    private bool EstaProyectoSeleccionado(int proyectoId) => _proyectosSeleccionados.Contains(proyectoId);

    private void CambiarSeleccionProyecto(int proyectoId, bool seleccionado)
    {
        if (seleccionado)
        {
            _proyectosSeleccionados.Add(proyectoId);
        }
        else
        {
            _proyectosSeleccionados.Remove(proyectoId);
        }
    }

    private string ClaseTarjetaProyecto(int proyectoId)
    {
        var clases = "project-card project-card--score";

        if (_modoSeleccionInformes)
