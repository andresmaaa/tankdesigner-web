@page "/mis-proyectos"

@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Newtonsoft.Json
@using TankDesigner.Core.Models
@using TankDesigner.Web.Data
@using TankDesigner.Web.Services

@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject ProyectoPersistenciaService ProyectoPersistenciaService
@inject ProyectoState EstadoProyecto
@inject NavigationManager NavigationManager
@inject AdminService AdminService
@inject InvitacionesService InvitacionesService
@inject PdfRenderService PdfRenderService
@inject InformeResumenProyectosService InformeResumenProyectosService

<PageTitle>Mis proyectos</PageTitle>

<div class="gestion-proyectos-page">
    <section class="gestion-hero">
        <div>
            <div class="gestion-kicker">Centro de gestión</div>
            <h1>Mis proyectos</h1>
            <p>
                Accede a tus proyectos, continúa el flujo técnico de diseño y administra la información
                guardada de la plataforma desde un único punto de entrada.
            </p>
        </div>

        <div class="gestion-hero__actions">
            @if (_modoActivo == "mis")
            {
                <button type="button" class="btn-pro btn-pro--primary" @onclick="NuevoProyecto">
                    Nuevo proyecto
                </button>

                @if (_misProyectos.Any())
                {
                    <button type="button" class="btn-pro btn-pro--dark" @onclick="AbrirProyectoReciente">
                        Continuar último proyecto
                    </button>

                    @if (!_modoSeleccionInformes)
                    {
                        <button type="button" class="btn-pro btn-pro--primary-soft" @onclick="ActivarModoSeleccionInformes">
                            Seleccionar informes
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn-pro btn-pro--ghost" @onclick="CancelarModoSeleccionInformes">
                            Cancelar selección
                        </button>
                    }
                }
            }
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(_mensaje))
    {
        <div class="gestion-alerta">
            <strong>Centro de gestión</strong>
            <span>@_mensaje</span>
        </div>
    }

    <section class="gestion-tabs">
        <button type="button" class="@ClaseModo("mis")" @onclick='() => CambiarModo("mis")'>
            <span class="tab-title">Mis proyectos</span>
            <span class="tab-subtitle">Trabajo personal</span>
        </button>

        @if (_esAdmin)
        {
            <button type="button" class="@ClaseModo("todos")" @onclick='() => CambiarModo("todos")'>
                <span class="tab-title">Todos los proyectos</span>
                <span class="tab-subtitle">Vista global</span>
            </button>

            <button type="button" class="@ClaseModo("usuarios")" @onclick='() => CambiarModo("usuarios")'>
                <span class="tab-title">Usuarios</span>
                <span class="tab-subtitle">Permisos y roles</span>
            </button>
        }
    </section>

    @if (_modoActivo == "mis")
    {
        <section class="gestion-bloque">
            <div class="bloque-header">
                <div>
                    <div class="gestion-kicker">Bloque 01</div>
                    <h2>Proyectos del usuario</h2>
                    <p>Listado de proyectos asociados al usuario actual.</p>
                </div>

                <div class="bloque-meta">
                    <span class="pill pill--soft">@MisProyectosFiltrados.Count() resultado(s)</span>
                </div>
            </div>

            <div class="search-toolbar">
                <div class="search-box">
                    <span class="search-box__icon">⌕</span>
                    <input class="search-box__input"
                           type="text"
                           placeholder="Buscar por nombre, cliente, normativa o fabricante..."
                           @bind="_busquedaMisProyectos"
                           @bind:event="oninput" />
                </div>

                @if (!string.IsNullOrWhiteSpace(_busquedaMisProyectos))
                {
                    <button type="button" class="btn-inline btn-inline--neutral" @onclick="LimpiarBusquedaMisProyectos">
                        Limpiar
                    </button>
                }
            </div>

            @if (_modoSeleccionInformes && _misProyectos.Any())
            {
                <div class="bulk-report-panel">
                    <div class="bulk-report-panel__copy">
                        <div class="gestion-kicker">Informe resumen</div>
                        <h3>Selección múltiple de presupuestos</h3>
                        <p>
                            Marca los proyectos que quieras consolidar. El informe generará el resumen económico
                            individual de cada proyecto y el total global final en un documento listo para imprimir.
                        </p>
                    </div>

                    <div class="bulk-report-panel__meta">
                        <span class="pill pill--soft">@_proyectosSeleccionados.Count seleccionado(s)</span>
                    </div>

                    <div class="bulk-report-panel__actions">
                        <button type="button" class="btn-pro btn-pro--primary-soft" @onclick="SeleccionarTodosInformes">
                            Seleccionar todos
                        </button>

                        <button type="button" class="btn-pro btn-pro--ghost" @onclick="LimpiarSeleccionInformes">
                            Limpiar selección
                        </button>

                        <button type="button" class="btn-pro btn-pro--dark" @onclick="VistaPreviaInformeResumenAsync">
                            Vista previa
                        </button>

                        <button type="button" class="btn-pro btn-pro--primary" @onclick="ImprimirInformeResumenAsync">
                            Imprimir
                        </button>

                        <button type="button" class="btn-pro btn-pro--primary" @onclick="DescargarInformeResumenPdfAsync">
                            Descargar PDF
                        </button>
                    </div>
                </div>
            }

            @if (_misProyectos.Count == 0)
            {
                <div class="empty-state">
                    <h3>No tienes proyectos guardados todavía</h3>
                    <p>
                        Crea un proyecto nuevo desde aquí o guarda uno desde el módulo de informe.
                    </p>
                    <button type="button" class="btn-pro btn-pro--primary" @onclick="NuevoProyecto">
                        Crear proyecto
                    </button>
                </div>
            }
            else if (!MisProyectosFiltrados.Any())
            {
                <div class="empty-state empty-state--small">
                    <h3>No se han encontrado proyectos</h3>
                    <p>Prueba con otro término de búsqueda o limpia el filtro actual.</p>
                </div>
            }
            else
            {
                <div class="cards-grid">
                    @foreach (var proyecto in MisProyectosFiltrados.OrderByDescending(p => p.FechaModificacion))
                    {
                        var score = CalcularScoreTecnico(proyecto);
                        var estadoProyecto = ObtenerEstadoProyecto(score);

                        <article class="@ClaseTarjetaProyecto(proyecto.Id)">
                            <div class="project-card__top">
                                <div>
                                    @if (_modoSeleccionInformes)
                                    {
                                        <label class="project-select-toggle">
                                            <input type="checkbox"
                                                   checked="@EstaProyectoSeleccionado(proyecto.Id)"
                                                   @onchange="e => CambiarSeleccionProyecto(proyecto.Id, e.Value is bool marcado && marcado)" />
                                            <span>Incluir en informe resumen</span>
                                        </label>
                                    }

                                    <span class="project-badge">Proyecto</span>
                                    <h3>@proyecto.Nombre</h3>

                                    <div class="project-card__status-row">
                                        <span class="project-status @estadoProyecto.ClaseCss">
                                            @estadoProyecto.Texto
                                        </span>
                                    </div>
                                </div>

                                <div class="project-card__date">
                                    @proyecto.FechaModificacion.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                </div>
                            </div>

                            <div class="project-card__body">
                                <div class="project-info">
                                    <span class="project-info__label">Cliente</span>
                                    <span class="project-info__value">
                                        @(string.IsNullOrWhiteSpace(proyecto.Cliente) ? "—" : proyecto.Cliente)
                                    </span>
                                </div>

                                <div class="project-info">
                                    <span class="project-info__label">Normativa</span>
                                    <span class="project-info__value">
                                        @(string.IsNullOrWhiteSpace(proyecto.Normativa) ? "—" : proyecto.Normativa)
                                    </span>
                                </div>

                                <div class="project-info">
                                    <span class="project-info__label">Fabricante</span>
                                    <span class="project-info__value">
                                        @(string.IsNullOrWhiteSpace(proyecto.Fabricante) ? "—" : proyecto.Fabricante)
                                    </span>
                                </div>
                            </div>

                            <div class="project-score">
                                <div class="project-score__head">
                                    <div>
                                        <span class="project-score__eyebrow">Score técnico</span>
                                        <div class="project-score__value">@score.Porcentaje%</div>
                                    </div>

                                    <span class="score-status @score.ClaseEstado">
                                        @score.EstadoTexto
                                    </span>
                                </div>

                                <div class="project-score__bar">
                                    <div class="project-score__bar-fill @score.ClaseEstado" style="width:@($"{score.Porcentaje}%")"></div>
                                </div>

                                <div class="project-score__meta">
                                    <span>@score.Resumen</span>
                                </div>

                                @if (score.Recomendaciones.Any())
                                {
                                    <div class="project-score__tips">
                                        @foreach (var recomendacion in score.Recomendaciones.Take(3))
                                        {
                                            <div class="project-score__tip">@recomendacion</div>
                                        }
                                    </div>
                                }
                            </div>

                            <div class="project-card__actions">
                                <button type="button" class="btn-pro btn-pro--dark" @onclick="() => AbrirMiProyecto(proyecto.Id)">
                                    Abrir
                                </button>

                                <button type="button" class="btn-pro btn-pro--primary-soft" @onclick="() => DuplicarMiProyecto(proyecto.Id)">
                                    Duplicar
                                </button>

                                <button type="button" class="btn-pro btn-pro--ghost" @onclick="() => ConfirmarEliminarMiProyecto(proyecto.Id)">
                                    Eliminar
                                </button>
                            </div>
                        </article>
                    }
                </div>
            }
        </section>
    }

    @if (_modoActivo == "todos" && _esAdmin)
    {
        <section class="gestion-bloque">
            <div class="bloque-header">
                <div>
                    <div class="gestion-kicker">Bloque 02</div>
                    <h2>Todos los proyectos</h2>
                    <p>Vista global de proyectos guardados por todos los usuarios.</p>
                </div>

                <div class="bloque-meta">
                    <span class="pill pill--soft">@TodosLosProyectosFiltrados.Count() resultado(s)</span>
                </div>
            </div>

            <div class="search-toolbar">
                <div class="search-box">
                    <span class="search-box__icon">⌕</span>
                    <input class="search-box__input"
                           type="text"
                           placeholder="Buscar proyecto, usuario, cliente, normativa o fabricante..."
                           @bind="_busquedaTodosLosProyectos"
                           @bind:event="oninput" />
                </div>

                @if (!string.IsNullOrWhiteSpace(_busquedaTodosLosProyectos))
                {
                    <button type="button" class="btn-inline btn-inline--neutral" @onclick="LimpiarBusquedaTodosLosProyectos">
                        Limpiar
                    </button>
                }
            </div>

            @if (_todosLosProyectos.Count == 0)
            {
                <div class="empty-state empty-state--small">
                    <h3>No hay proyectos guardados</h3>
                    <p>Todavía no existen registros globales en la plataforma.</p>
                </div>
            }
            else if (!TodosLosProyectosFiltrados.Any())
            {
                <div class="empty-state empty-state--small">
                    <h3>No se han encontrado proyectos</h3>
                    <p>No hay coincidencias con la búsqueda actual.</p>
                </div>
            }
            else
            {
                <div class="table-shell">
                    <table class="pro-table">
                        <thead>
                            <tr>
                                <th>Proyecto</th>
                                <th>Usuario</th>
                                <th>Cliente</th>
                                <th>Normativa</th>
                                <th>Fabricante</th>
                                <th>Modificación</th>
                                <th class="table-actions-col">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var proyecto in TodosLosProyectosFiltrados.OrderByDescending(p => p.FechaModificacion))
                            {
                                <tr>
                                    <td>
                                        <div class="table-main">
                                            <strong>@proyecto.Nombre</strong>
                                        </div>
                                    </td>
                                    <td>@proyecto.EmailUsuario</td>
                                    <td>@(string.IsNullOrWhiteSpace(proyecto.Cliente) ? "—" : proyecto.Cliente)</td>
                                    <td>@(string.IsNullOrWhiteSpace(proyecto.Normativa) ? "—" : proyecto.Normativa)</td>
                                    <td>@(string.IsNullOrWhiteSpace(proyecto.Fabricante) ? "—" : proyecto.Fabricante)</td>
                                    <td>@proyecto.FechaModificacion.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="table-actions">
                                        <button type="button" class="btn-inline btn-inline--danger" @onclick="() => ConfirmarEliminarProyectoGlobal(proyecto.Id)">
                                            Eliminar
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    }

    @if (_modoActivo == "usuarios" && _esAdmin)
    {
        <section class="gestion-bloque">
            <div class="bloque-header">
                <div>
                    <div class="gestion-kicker">Bloque 03</div>
                    <h2>Usuarios</h2>
                    <p>Gestión de permisos de administrador dentro de la plataforma.</p>
                </div>

                <div class="bloque-meta">
                    <span class="pill pill--soft">@UsuariosFiltrados.Count() usuario(s)</span>
                </div>
            </div>

            @if (_esSuperAdmin)
            {
                <div class="invite-panel">
                    <div class="invite-panel__header">
                        <div>
                            <div class="gestion-kicker">Invitaciones</div>
                            <h3>Crear enlace de invitación</h3>
                            <p>
                                Genera un enlace para enviarlo manualmente por WhatsApp o correo.
                                Cuando el invitado entre con ese correo, se le aplicará el rol indicado.
                            </p>
                        </div>
                    </div>

                    <div class="invite-grid">
                        <div class="invite-field">
                            <label for="correoInvitacion">Correo del invitado</label>
                            <input id="correoInvitacion"
                                   class="invite-input"
                                   type="email"
                                   placeholder="correo@empresa.com"
                                   @bind="_correoInvitacion" />
                        </div>

                        <div class="invite-field">
                            <label for="rolInvitacion">Rol invitado</label>
                            <select id="rolInvitacion" class="invite-input" @bind="_rolInvitacion">
                                <option value="Admin">Admin</option>
                                <option value="SuperAdmin">SuperAdmin</option>
                            </select>
                        </div>

                        <div class="invite-actions">
                            <button type="button" class="btn-pro btn-pro--primary" @onclick="GenerarInvitacionAsync">
                                Generar enlace
                            </button>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_enlaceInvitacionGenerado))
                    {
                        <div class="invite-result">
                            <div class="invite-result__label">Enlace generado</div>
                            <div class="invite-result__box">@_enlaceInvitacionGenerado</div>

                            <div class="invite-result__actions">
                                <button type="button" class="btn-pro btn-pro--dark" @onclick="CopiarEnlaceInvitacionAsync">
                                    Copiar enlace
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }

            <div class="search-toolbar">
                <div class="search-box">
                    <span class="search-box__icon">⌕</span>
                    <input class="search-box__input"
                           type="text"
                           placeholder="Buscar por correo, nombre o rol..."
                           @bind="_busquedaUsuarios"
                           @bind:event="oninput" />
                </div>

                @if (!string.IsNullOrWhiteSpace(_busquedaUsuarios))
                {
                    <button type="button" class="btn-inline btn-inline--neutral" @onclick="LimpiarBusquedaUsuarios">
                        Limpiar
                    </button>
                }
            </div>

            @if (_usuarios.Count == 0)
            {
                <div class="empty-state empty-state--small">
                    <h3>No hay usuarios registrados</h3>
                    <p>No existen cuentas disponibles en la aplicación.</p>
                </div>
            }
            else if (!UsuariosFiltrados.Any())
            {
                <div class="empty-state empty-state--small">
                    <h3>No se han encontrado usuarios</h3>
                    <p>No hay coincidencias con la búsqueda actual.</p>
                </div>
            }
            else
            {
                <div class="table-shell">
                    <table class="pro-table">
                        <thead>
                            <tr>
                                <th>Correo</th>
                                <th>Nombre</th>
                                <th>Rol actual</th>
                                <th class="table-actions-col">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var usuario in UsuariosFiltrados.OrderBy(u => u.Email))
                            {
                                <tr>
                                    <td>@usuario.Email</td>
                                    <td>@(string.IsNullOrWhiteSpace(usuario.NombreCompleto) ? "—" : usuario.NombreCompleto)</td>
                                    <td>
                                        <span class="@ObtenerClaseRol(usuario)">
                                            @ObtenerTextoRol(usuario)
                                        </span>
                                    </td>
                                    <td class="table-actions">
                                        @if (usuario.EsSuperAdmin)
                                        {
                                            <button type="button" class="btn-inline btn-inline--disabled" disabled>
                                                SuperAdmin protegido
                                            </button>
                                        }
                                        else if (!usuario.EsAdmin)
                                        {
                                            <button type="button" class="btn-inline btn-inline--primary" @onclick="() => HacerAdmin(usuario.Id)">
                                                Hacer admin
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn-inline btn-inline--neutral" @onclick="() => QuitarAdmin(usuario.Id)">
                                                Quitar admin
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    }
</div>

<style>
        .project-card--score {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .project-score {
            margin-top: 4px;
            padding: 16px;
            border-radius: 18px;
            background: linear-gradient(180deg, rgba(255,255,255,0.86), rgba(248,250,252,0.98));
            border: 1px solid rgba(148, 163, 184, 0.18);
            box-shadow: 0 8px 24px rgba(15, 23, 42, 0.06), inset 0 1px 0 rgba(255,255,255,0.7);
        }

        .project-score__head {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 12px;
            margin-bottom: 12px;
        }

        .project-score__eyebrow {
            display: block;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: #64748b;
            margin-bottom: 4px;
        }

        .project-score__value {
            font-size: 28px;
            font-weight: 800;
            line-height: 1;
            color: #0f172a;
        }

        .score-status {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 8px 12px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 700;
            white-space: nowrap;
            border: 1px solid transparent;
        }

            .score-status.score--incompleto {
                background: rgba(239, 68, 68, 0.10);
                color: #b91c1c;
                border-color: rgba(239, 68, 68, 0.18);
            }

            .score-status.score--revisar {
                background: rgba(245, 158, 11, 0.12);
                color: #b45309;
                border-color: rgba(245, 158, 11, 0.22);
            }

            .score-status.score--listo {
                background: rgba(16, 185, 129, 0.12);
                color: #047857;
                border-color: rgba(16, 185, 129, 0.22);
            }

        .project-score__bar {
            width: 100%;
            height: 12px;
            border-radius: 999px;
            overflow: hidden;
            background: rgba(226, 232, 240, 0.9);
            box-shadow: inset 0 1px 2px rgba(15, 23, 42, 0.08);
        }

        .project-score__bar-fill {
            height: 100%;
            border-radius: 999px;
            transition: width .35s ease;
        }

            .project-score__bar-fill.score--incompleto {
                background: linear-gradient(90deg, #f87171, #ef4444);
            }

            .project-score__bar-fill.score--revisar {
                background: linear-gradient(90deg, #fbbf24, #f59e0b);
            }

            .project-score__bar-fill.score--listo {
                background: linear-gradient(90deg, #34d399, #10b981);
            }

        .project-score__meta {
            margin-top: 10px;
            font-size: 13px;
            color: #475569;
        }

        .project-score__tips {
            margin-top: 12px;
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .project-score__tip {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 8px 10px;
            border-radius: 999px;
            background: rgba(15, 23, 42, 0.045);
            color: #334155;
            font-size: 12px;
            font-weight: 600;
            line-height: 1.2;
        }

            .project-score__tip::before {
                content: "•";
                color: #6366f1;
                font-size: 14px;
                line-height: 1;
            }

        .invite-panel {
            margin-bottom: 20px;
            padding: 20px;
            border-radius: 22px;
            border: 1px solid rgba(148, 163, 184, 0.20);
            background: linear-gradient(180deg, rgba(255,255,255,0.94), rgba(248,250,252,0.98));
            box-shadow: 0 10px 28px rgba(15, 23, 42, 0.05);
        }

        .invite-panel__header h3 {
            margin: 4px 0 8px 0;
            font-size: 22px;
            font-weight: 800;
            color: #0f172a;
        }

        .invite-panel__header p {
            margin: 0;
            color: #475569;
            line-height: 1.55;
        }

        .invite-grid {
            display: grid;
            grid-template-columns: 1.4fr 0.8fr auto;
            gap: 14px;
            align-items: end;
            margin-top: 18px;
        }

        .invite-field {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

            .invite-field label {
                font-size: 13px;
                font-weight: 700;
                color: #334155;
            }

        .invite-input {
            width: 100%;
            min-height: 46px;
            padding: 0 14px;
            border-radius: 14px;
            border: 1px solid #cbd5e1;
            background: #fff;
            font-size: 14px;
            color: #0f172a;
            outline: none;
            transition: border-color .2s ease, box-shadow .2s ease;
        }

            .invite-input:focus {
                border-color: #2563eb;
                box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.10);
            }

        .invite-actions {
            display: flex;
            align-items: end;
        }

        .invite-result {
            margin-top: 18px;
            padding: 16px;
            border-radius: 18px;
