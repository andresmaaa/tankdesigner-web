        if (_proyectosSeleccionados.Contains(proyectoId))
            clases += " project-card--selected";

        return clases;
    }

    private List<ProyectoEntidad> ObtenerProyectosSeleccionados()
    {
        return _misProyectos
            .Where(p => _proyectosSeleccionados.Contains(p.Id))
            .OrderByDescending(p => p.FechaModificacion)
            .ToList();
    }

    private string ConstruirHtmlInformeResumen()
    {
        var proyectos = ObtenerProyectosSeleccionados();
        return InformeResumenProyectosService.GenerarInformeResumenPresupuestos(proyectos);
    }

    private bool ValidarSeleccionInformeResumen()
    {
        if (!_proyectosSeleccionados.Any())
        {
            _mensaje = "Debes marcar al menos un proyecto para generar el informe resumen.";
            return false;
        }

        return true;
    }

    private async Task VistaPreviaInformeResumenAsync()
    {
        try
        {
            _mensaje = "";

            if (!ValidarSeleccionInformeResumen())
                return;

            var html = ConstruirHtmlInformeResumen();

            var ok = await JS.InvokeAsync<bool>(
                "tankInformes.openPreview",
                "Resumen global de presupuestos",
                html);

            if (!ok)
                _mensaje = "No se pudo abrir la vista previa del informe resumen.";
        }
        catch (Exception ex)
        {
            _mensaje = $"Error al abrir la vista previa del informe resumen: {ex.Message}";
        }
    }

    private async Task ImprimirInformeResumenAsync()
    {
        try
        {
            _mensaje = "";

            if (!ValidarSeleccionInformeResumen())
                return;

            var html = ConstruirHtmlInformeResumen();

            var ok = await JS.InvokeAsync<bool>(
                "tankInformes.openPreviewAndPrint",
                "Resumen global de presupuestos",
                html);

            if (!ok)
                _mensaje = "No se pudo abrir la ventana de impresión del informe resumen.";
        }
        catch (Exception ex)
        {
