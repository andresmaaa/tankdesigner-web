    private async Task GenerarInvitacionAsync()
    {
        if (!_esSuperAdmin || _usuarioActual == null)
            return;

        _mensaje = "";
        _enlaceInvitacionGenerado = "";

        var correoNormalizado = (_correoInvitacion ?? string.Empty).Trim().ToLowerInvariant();

        if (string.IsNullOrWhiteSpace(correoNormalizado))
        {
            _mensaje = "Debes indicar un correo para la invitación.";
            return;
        }

        if (_rolInvitacion != RolesAplicacion.Admin && _rolInvitacion != RolesAplicacion.SuperAdmin)
        {
            _mensaje = "El rol seleccionado no es válido.";
            return;
        }

        try
        {
            var resultado = await InvitacionesService.CrearInvitacionAsync(
                correoNormalizado,
                _rolInvitacion,
                _usuarioActual.Id);

            if (resultado == null)
            {
                _mensaje = "No se pudo generar la invitación.";
                return;
            }

            _mensaje = resultado.Mensaje;

            if (!resultado.Ok || string.IsNullOrWhiteSpace(resultado.Token))
            {
                return;
            }

            _enlaceInvitacionGenerado =
                $"{NavigationManager.BaseUri.TrimEnd('/')}/invitacion/{Uri.EscapeDataString(resultado.Token)}?email={Uri.EscapeDataString(resultado.Email)}";

            _correoInvitacion = "";
            _rolInvitacion = RolesAplicacion.Admin;

            await CargarTodoAsync();
            _modoActivo = "usuarios";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _mensaje = $"Se produjo un error al generar la invitación: {ex.Message}";
        }
    }

