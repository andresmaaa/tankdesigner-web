    private ScoreTecnicoViewModel CalcularScoreTecnico(ProyectoEntidad entidad)
    {
        var proyecto = DeserializarSeguro<ProyectoGeneralModel>(entidad.ProyectoJson);
        var tanque = DeserializarSeguro<TankModel>(entidad.TanqueJson);
        var cargas = DeserializarSeguro<CargasModel>(entidad.CargasJson);
        var instalacion = DeserializarSeguro<InstalacionModel>(entidad.InstalacionJson);
        var resultado = DeserializarSeguro<ResultadoCalculoModel>(entidad.ResultadoJson);

        var bloquesCompletos = 0;
        var recomendaciones = new List<string>();

        if (TieneProyectoCompleto(proyecto))
        {
            bloquesCompletos++;
        }
        else
        {
            recomendaciones.Add("Falta completar la configuración general del proyecto.");
        }

        if (TieneGeometriaCompleta(tanque))
        {
            bloquesCompletos++;
        }
        else
        {
            recomendaciones.Add("Faltan datos de geometría del tanque.");
        }

        if (TieneCargasCompletas(cargas))
        {
            bloquesCompletos++;
        }
        else
        {
            recomendaciones.Add("Faltan cargas o condiciones de diseño.");
        }

        if (TieneInstalacionCompleta(instalacion))
        {
            bloquesCompletos++;
        }
        else
        {
            recomendaciones.Add("Faltan datos de instalación y montaje.");
        }

        if (TieneResultadoCalculado(resultado))
        {
            bloquesCompletos++;
        }
        else
        {
            recomendaciones.Add("No hay resultado calculado todavía.");
        }

        var porcentaje = bloquesCompletos * 20;

        var estadoTexto = "Incompleto";
        var claseEstado = "score--incompleto";

        if (porcentaje >= 80)
        {
            estadoTexto = "Listo";
            claseEstado = "score--listo";
        }
        else if (porcentaje >= 40)
        {
            estadoTexto = "Revisar";
            claseEstado = "score--revisar";
        }

        var resumen = $"{bloquesCompletos}/5 bloques técnicos completados";

        if (porcentaje == 100)
        {
            resumen = "Proyecto listo para continuar con revisión e informe.";
        }

        return new ScoreTecnicoViewModel
        {
            Porcentaje = porcentaje,
            EstadoTexto = estadoTexto,
            ClaseEstado = claseEstado,
            Resumen = resumen,
            Recomendaciones = recomendaciones
        };
    }

    private static T DeserializarSeguro<T>(string? json) where T : new()
    {
        if (string.IsNullOrWhiteSpace(json))
            return new T();

        try
        {
            return JsonConvert.DeserializeObject<T>(json) ?? new T();
        }
        catch
        {
            return new T();
        }
    }

    private static bool TieneProyectoCompleto(ProyectoGeneralModel? proyecto)
    {
        if (proyecto == null)
            return false;

        return !string.IsNullOrWhiteSpace(proyecto.NombreProyecto)
               && !string.IsNullOrWhiteSpace(proyecto.Normativa)
               && !string.IsNullOrWhiteSpace(proyecto.Fabricante)
               && !string.IsNullOrWhiteSpace(proyecto.MaterialPrincipal)
               && !string.IsNullOrWhiteSpace(proyecto.ModeloCalculo);
    }

    private static bool TieneGeometriaCompleta(TankModel? tanque)
    {
        if (tanque == null)
            return false;

        return tanque.ChapasPorAnillo > 0
               && tanque.NumeroAnillos > 0
               && tanque.AnilloArranque > 0
               && tanque.DensidadLiquido > 0
               && !string.IsNullOrWhiteSpace(tanque.Modelo)
               && tanque.Diametro > 0
               && tanque.AlturaTotal > 0
               && tanque.AlturaPanelBase > 0;
    }

    private static bool TieneCargasCompletas(CargasModel? cargas)
    {
        if (cargas == null)
            return false;

        if (string.IsNullOrWhiteSpace(cargas.NormativaAplicada))
            return false;

        var tieneDatosBase =
            cargas.DensidadLiquido > 0 ||
            cargas.VelocidadViento > 0 ||
            cargas.SnowLoad > 0;

        var tieneDatosAwwaTecho =
            !string.IsNullOrWhiteSpace(cargas.RoofType) ||
            cargas.RoofDeadLoad > 0 ||
            cargas.RoofSnowLoad > 0 ||
            cargas.RoofLiveLoad > 0 ||
            cargas.RoofCentroid > 0 ||
            cargas.RoofProjectedArea > 0 ||
            !string.IsNullOrWhiteSpace(cargas.RoofAngle);

        var tieneDatosViento =
            !string.IsNullOrWhiteSpace(cargas.ClaseExposicion) ||
            cargas.VelocidadViento > 0;

        var tieneDatosSismo =
            cargas.Ss > 0 ||
            cargas.S1 > 0 ||
            cargas.TL > 0 ||
            !string.IsNullOrWhiteSpace(cargas.SiteClass) ||
            !string.IsNullOrWhiteSpace(cargas.SeismicUseGroup);

        return tieneDatosBase || tieneDatosAwwaTecho || tieneDatosViento || tieneDatosSismo;
    }

    private static bool TieneInstalacionCompleta(InstalacionModel? instalacion)
    {
        if (instalacion == null)
            return false;

        return !string.IsNullOrWhiteSpace(instalacion.TipoTecho)
               && !string.IsNullOrWhiteSpace(instalacion.TipoEscalera)
               && !string.IsNullOrWhiteSpace(instalacion.LugarObra)
               && instalacion.TamanoCuadrilla > 0
               && instalacion.HorasTrabajoDia > 0;
    }

    private static bool TieneResultadoCalculado(ResultadoCalculoModel? resultado)
    {
        if (resultado == null)
            return false;

        return resultado.Anillos.Any()
               || resultado.EsValido
               || resultado.NumeroAnillos > 0
               || resultado.Diametro > 0
               || resultado.AlturaTotal > 0
               || resultado.TieneConfiguracion
               || resultado.TieneTornilloBase
               || resultado.TieneSeleccionRealCalculada;
    }

    private class ScoreTecnicoViewModel
    {
        public int Porcentaje { get; set; }
        public string EstadoTexto { get; set; } = "";
        public string ClaseEstado { get; set; } = "";
        public string Resumen { get; set; } = "";
        public List<string> Recomendaciones { get; set; } = new();
    }
}