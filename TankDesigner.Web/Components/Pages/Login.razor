@page "/login"
@using Microsoft.AspNetCore.WebUtilities
@inject NavigationManager NavigationManager

<PageTitle>Iniciar sesión</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-card__header">
            <h1>Iniciar sesión</h1>
            <p>Accede para descargar informes y trabajar con tus proyectos guardados.</p>
        </div>

        @if (MostrarError())
        {
            <div class="auth-alert auth-alert--error">
                Correo o contraseña incorrectos.
            </div>
        }

        @if (MostrarInvitacion())
        {
            <div class="auth-alert auth-alert--success">
                Tienes una invitación pendiente. Al iniciar sesión se activará automáticamente.
            </div>
        }

        <form method="post" action="/auth/login">
            <div class="auth-form">
                <input type="hidden" name="returnUrl" value="@ObtenerReturnUrl()" />

                <div class="auth-field">
                    <label for="email">Correo electrónico</label>
                    <input id="email" name="email" class="auth-input" type="email" required value="@ObtenerEmail()" />
                </div>

                <div class="auth-field">
                    <label for="password">Contraseña</label>
                    <input id="password" name="password" class="auth-input" type="password" required />
                </div>

                <button type="submit" class="auth-btn">
                    Entrar
                </button>
            </div>
        </form>

        <div class="auth-footer">
            ¿No tienes cuenta?
            <a href="@ObtenerUrlRegistro()">Crear cuenta</a>
        </div>
    </div>
</div>

@code {
    private bool MostrarError()
    {
        var query = ObtenerQuery();
        return query.ContainsKey("error");
    }

    private bool MostrarInvitacion()
    {
        var query = ObtenerQuery();
        return query.ContainsKey("email");
    }

    private string ObtenerReturnUrl()
    {
        var query = ObtenerQuery();

        if (query.TryGetValue("returnUrl", out var returnUrl) && !string.IsNullOrWhiteSpace(returnUrl))
            return returnUrl.ToString();

        return "/mis-proyectos";
    }

    private string ObtenerEmail()
    {
        var query = ObtenerQuery();

        if (query.TryGetValue("email", out var email) && !string.IsNullOrWhiteSpace(email))
            return email.ToString();

        return string.Empty;
    }

    private string ObtenerUrlRegistro()
    {
        var email = ObtenerEmail();
        return string.IsNullOrWhiteSpace(email)
            ? "/register"
            : $"/register?email={Uri.EscapeDataString(email)}";
    }

    private Dictionary<string, Microsoft.Extensions.Primitives.StringValues> ObtenerQuery()
    {
        var uri = new Uri(NavigationManager.Uri);
        return QueryHelpers.ParseQuery(uri.Query).ToDictionary(x => x.Key, x => x.Value);
    }
}
