@page "/login"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Antiforgery
@using Microsoft.AspNetCore.Http

@attribute [AllowAnonymous]

@inject NavigationManager NavigationManager
@inject IAntiforgery Antiforgery
@inject IHttpContextAccessor HttpContextAccessor

<PageTitle>Iniciar sesión</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-card__header">
            <h1>Iniciar sesión</h1>
            <p>Accede para trabajar con tus proyectos guardados.</p>
        </div>
        @if (MostrarError())
        {
            <div class="auth-alert auth-alert--error">
                Correo o contraseña incorrectos.
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(ObtenerTokenInvitacion()))
        {
            <div class="auth-alert auth-alert--success">
                Has accedido mediante una invitación. Inicia sesión con el correo invitado para aplicar el rol.
            </div>
        }

        <form method="post" action="/auth/login">
            <input type="hidden" name="__RequestVerificationToken" value="@_token" />
            <input type="hidden" name="returnUrl" value="@ObtenerReturnUrl()" />
            <input type="hidden" name="token" value="@ObtenerTokenInvitacion()" />

            <div class="auth-form">
                <div class="auth-field">
                    <label for="email">Correo electrónico</label>
                    <input id="email"
                           name="email"
                           class="auth-input"
                           type="email"
                           value="@ObtenerEmailInvitado()"
                           inputmode="email"
                           autocomplete="username"
                           autocapitalize="off"
                           spellcheck="false"
                           readonly="@EmailBloqueadoPorInvitacion()"
                           required />
                </div>

                <div class="auth-field">
                    <label for="password">Contraseña</label>
                    <input id="password"
                           name="password"
                           class="auth-input"
                           type="password"
                           autocomplete="current-password"
                           required />
                </div>

                <div class="auth-field auth-field--checkbox">
                    <label class="auth-checkbox">
                        <input type="checkbox" name="rememberMe" value="true" checked />
                        <span>Mantener sesión iniciada</span>
                    </label>
                </div>

                <button type="submit" class="auth-btn">
                    Entrar
                </button>
            </div>
        </form>

        <div class="auth-footer">
            ¿No tienes cuenta?
            <a href="@ObtenerRutaRegistro()">Crear cuenta</a>
        </div>
    </div>
</div>

@code {
    private string _token = string.Empty;

    protected override void OnInitialized()
    {
        var httpContext = HttpContextAccessor.HttpContext;
        if (httpContext is not null)
        {
            var tokens = Antiforgery.GetAndStoreTokens(httpContext);
            _token = tokens.RequestToken ?? string.Empty;
        }
    }

    private bool MostrarError()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        return query.ContainsKey("error");
    }


    private string ObtenerReturnUrl()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("returnUrl", out var returnUrl) && !string.IsNullOrWhiteSpace(returnUrl))
            return returnUrl.ToString();

        return "/mis-proyectos";
    }

    private string ObtenerTokenInvitacion()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("token", out var token))
            return token.ToString();

        return string.Empty;
    }

    private string ObtenerEmailInvitado()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("email", out var email))
            return email.ToString();

        return string.Empty;
    }

    private bool EmailBloqueadoPorInvitacion()
    {
        return !string.IsNullOrWhiteSpace(ObtenerTokenInvitacion()) &&
               !string.IsNullOrWhiteSpace(ObtenerEmailInvitado());
    }

    private string ObtenerRutaRegistro()
    {
        var token = ObtenerTokenInvitacion();
        var email = ObtenerEmailInvitado();

        if (!string.IsNullOrWhiteSpace(token))
            return $"/register?token={Uri.EscapeDataString(token)}&email={Uri.EscapeDataString(email)}";

        return "/register";
    }
}
