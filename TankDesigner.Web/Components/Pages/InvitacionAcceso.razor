@page "/invitacion/{Token}"
@using Microsoft.AspNetCore.Identity
@using TankDesigner.Web.Data
@using TankDesigner.Web.Services

@inject InvitacionesService InvitacionesService
@inject NavigationManager NavigationManager
@inject UserManager<ApplicationUser> UserManager

<PageTitle>Invitación</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-card__header">
            <h1>Procesando invitación</h1>
            <p>Estamos validando tu acceso invitado.</p>
        </div>

        <div class="auth-form">
            <p>@_mensaje</p>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string Token { get; set; } = string.Empty;

    private string _mensaje = "Validando invitación...";

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(Token))
        {
            _mensaje = "La invitación no es válida.";
            return;
        }

        var invitacion = await InvitacionesService.ObtenerInvitacionValidaPorTokenAsync(Token);

        if (invitacion == null)
        {
            _mensaje = "La invitación ha caducado o ya ha sido utilizada.";
            return;
        }

        var usuarioExistente = await UserManager.FindByEmailAsync(invitacion.Email);

        var tokenEscapado = Uri.EscapeDataString(Token);
        var emailEscapado = Uri.EscapeDataString(invitacion.Email);

        if (usuarioExistente is not null)
        {
            var tienePassword = await UserManager.HasPasswordAsync(usuarioExistente);

            if (tienePassword)
            {
                var destinoLogin = $"/login?token={tokenEscapado}&email={emailEscapado}";
                NavigationManager.NavigateTo(destinoLogin, forceLoad: true);
                return;
            }

            var destinoRegistroExistente = $"/register?token={tokenEscapado}&email={emailEscapado}";
            NavigationManager.NavigateTo(destinoRegistroExistente, forceLoad: true);
            return;
        }

        var destinoRegistro = $"/register?token={tokenEscapado}&email={emailEscapado}";
        NavigationManager.NavigateTo(destinoRegistro, forceLoad: true);
    }
}